# Solidigm Brand MCP — environment template
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ---------------------------------------------------------------------------
# Microsoft Entra (Azure AD) app registration — confidential client
# ---------------------------------------------------------------------------
# 1. Register an app in https://entra.microsoft.com → App registrations
# 2. Platform: Web (confidential client)
# 3. Redirect URI: {SERVER_BASE_URL}/microsoft/callback
# 4. Delegated permissions (admin-consented):
#      Sites.Read.All, User.Read, offline_access
# 5. Generate a client secret and paste it below
M365_TENANT_ID=your-tenant-guid
M365_CLIENT_ID=your-app-client-id
M365_CLIENT_SECRET=your-app-client-secret

# ---------------------------------------------------------------------------
# SharePoint document library (Graph composite IDs, not display names)
# See mcp/README.md for how to resolve these with curl / Graph Explorer.
# ---------------------------------------------------------------------------
BRAND_SHAREPOINT_SITE_ID=yourtenant.sharepoint.com,<site-guid>,<web-guid>
BRAND_SHAREPOINT_DRIVE_ID=<drive-guid>

# Cache TTL for SharePoint folder listings (seconds). Default: 3600 (1 hour).
BRAND_SHAREPOINT_CACHE_TTL=3600

# ---------------------------------------------------------------------------
# Server runtime
# ---------------------------------------------------------------------------
# Public base URL of this MCP server (used for the OAuth redirect URI).
# Must match one of the redirect URIs registered on the Entra app.
SERVER_BASE_URL=http://localhost:8080

# Host / port the server binds to
MCP_HOST=0.0.0.0
MCP_PORT=8080
