{
  "$description": "Solidigm shape language. The 45° notch is a brand-distinctive geometric primitive used in containers, backgrounds, and large surfaces.",
  "notch": {
    "angle": {
      "$type": "number",
      "$value": 45,
      "$description": "The canonical Solidigm notch angle, in degrees. Always 45° — a defining brand geometry."
    },
    "cut": {
      "sm": { "$type": "dimension", "$value": "96px",  "$description": "Mobile / compact notch cut size." },
      "md": { "$type": "dimension", "$value": "100px", "$description": "Tablet notch cut size." },
      "lg": { "$type": "dimension", "$value": "146px", "$description": "Desktop standard notch cut size." },
      "xl": { "$type": "dimension", "$value": "190px", "$description": "Footer / large surface notch (no image)." },
      "2xl":{ "$type": "dimension", "$value": "357px", "$description": "Footer / extra-large surface notch (with image)." }
    },
    "clipPath": {
      "topLeft":     { "$type": "string", "$value": "polygon(26% 0%, 100% 0%, 98% 100%, 0% 100%, 0% 45%)",  "$description": "45° notch in top-left corner." },
      "topRight":    { "$type": "string", "$value": "polygon(0% 0%, 45% 0%, 100% 45%, 100% 100%, 0% 100%)", "$description": "45° notch in top-right corner." },
      "bottomLeft":  { "$type": "string", "$value": "polygon(0% 0%, 100% 1%, 100% 100%, 45% 100%, 0% 75%)", "$description": "45° notch in bottom-left corner." },
      "bottomRight": { "$type": "string", "$value": "polygon(0% 0%, 100% 0%, 100% 60%, 45% 100%, 0% 100%)", "$description": "45° notch in bottom-right corner." }
    }
  },
  "border": {
    "width": {
      "hairline": { "$type": "dimension", "$value": "0.5px", "$description": "Hairline divider (cards, separators)." },
      "thin":     { "$type": "dimension", "$value": "1px",   "$description": "Default border (buttons, inputs, cards)." },
      "thick":    { "$type": "dimension", "$value": "2px",   "$description": "Emphasized border (active tab indicator, dividers)." },
      "heavy":    { "$type": "dimension", "$value": "4px",   "$description": "Heavy border (tab active indicator, button loader)." },
      "feature":  { "$type": "dimension", "$value": "8px",   "$description": "Feature/accent border (hero play buttons)." }
    }
  },
  "$extensions": {
    "com.solidigm.brand": {
      "rationale": "The 45° notch is the brand's signature large-surface geometry — used widely on sections, backgrounds, footer, bento boxes. Cut sizes scale with breakpoint, not arbitrarily.",
      "evidence": "Storybook + AEM both define the same $clipPaths map and the same notch dimensions per surface."
    }
  }
}
