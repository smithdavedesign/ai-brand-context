          "$description": "Subtle dividers."
        },
        "default": {
          "$type": "color",
          "$value": "{color.Dark.Dark Grey}",
          "$description": "Default border."
        },
        "emphasis": {
          "$type": "color",
          "$value": "{color.Dark.Solidigm Purple}",
          "$description": "Emphasized border (active states)."
        }
      },
      "feedback": {
        "error": {
          "$type": "color",
          "$value": "#ba3640",
          "$description": "Interface error / destructive action."
        },
        "warning": {
          "$type": "color",
          "$value": "#ff0000",
          "$description": "Warning / critical alert (use sparingly)."
        },
        "success": {
          "$type": "color",
          "$value": "{color.Accents.Electric Teal}",
