        },
        "info": {
          "$type": "color",
          "$value": "{color.Dark.Solidigm Purple}",
          "$description": "Informational state."
        }
      }
    },
    "space": {
      "gap": {
        "xs": {
          "$type": "dimension",
          "$value": "{space.2}",
          "$description": "Tight inline gap (8px)."
        },
        "sm": {
          "$type": "dimension",
          "$value": "{space.5}",
          "$description": "Standard small gap (20px)."
        },
        "md": {
          "$type": "dimension",
          "$value": "{space.8}",
          "$description": "Mobile primary gap (30px equivalent — uses 32 from clean scale)."
        },
        "lg": {
          "$type": "dimension",
          "$value": "{space.10}",
          "$description": "Desktop primary gap (40px)."
        },
        "xl": {
          "$type": "dimension",
          "$value": "{space.16}",
          "$description": "Large gap (64px)."
        }
      },
      "section": {
        "sm": {
          "$type": "dimension",
          "$value": "{space.18}",
          "$description": "Section padding mobile (72px)."
        },
        "md": {
          "$type": "dimension",
          "$value": "{space.25}",
          "$description": "Section padding tablet (100px)."
        },
        "lg": {
          "$type": "dimension",
          "$value": "{space.38}",
          "$description": "Section padding desktop (150px)."
        }
      },
      "inset": {
        "sm": {
          "$type": "dimension",
          "$value": "{space.5}",
          "$description": "Container inline padding small (20px)."
        },
        "md": {
          "$type": "dimension",
          "$value": "{space.8}",
          "$description": "Container inline padding medium (32px)."
        },
        "lg": {
          "$type": "dimension",
