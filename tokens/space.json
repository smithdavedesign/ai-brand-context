{
  "$description": "Solidigm canonical spacing primitives. 4px-based scale, vendor-neutral. Use semantic aliases (semantic/space.json) for component spacing decisions.",
  "space": {
    "0": { "$type": "dimension", "$value": "0px",   "$description": "No space." },
    "1": { "$type": "dimension", "$value": "4px",   "$description": "Hairline / icon padding." },
    "2": { "$type": "dimension", "$value": "8px",   "$description": "Tight inline gap." },
    "3": { "$type": "dimension", "$value": "12px",  "$description": "Compact gap." },
    "4": { "$type": "dimension", "$value": "16px",  "$description": "Default base unit ($spacer = 1rem)." },
    "5": { "$type": "dimension", "$value": "20px",  "$description": "Standard small gap." },
    "6": { "$type": "dimension", "$value": "24px",  "$description": "Medium gap." },
    "8": { "$type": "dimension", "$value": "32px",  "$description": "Section inner spacing (small)." },
    "10":{ "$type": "dimension", "$value": "40px",  "$description": "Desktop primary gap." },
    "12":{ "$type": "dimension", "$value": "48px",  "$description": "Large gap." },
    "14":{ "$type": "dimension", "$value": "56px",  "$description": "Extra large gap." },
    "16":{ "$type": "dimension", "$value": "64px",  "$description": "Generous spacing." },
    "18":{ "$type": "dimension", "$value": "72px",  "$description": "Section spacing (mobile)." },
    "20":{ "$type": "dimension", "$value": "80px",  "$description": "Container inline padding (xxl)." },
    "24":{ "$type": "dimension", "$value": "96px",  "$description": "Section spacing (compact)." },
    "25":{ "$type": "dimension", "$value": "100px", "$description": "Section spacing (tablet)." },
    "30":{ "$type": "dimension", "$value": "120px", "$description": "Hero block spacing." },
    "38":{ "$type": "dimension", "$value": "150px", "$description": "Section spacing (desktop)." }
  },
  "$extensions": {
    "com.solidigm.brand": {
      "baseUnit": "4px",
      "scaleType": "linear",
      "rationale": "Modern 4px grid (Tailwind/Material 3 aligned). Numeric keys = pixels/4. Bootstrap leftover values (28/56/88) intentionally omitted — no design rationale.",
      "evidence": "Derived from Storybook + AEM SCSS audit: $spacer * N values reduced to a clean linear scale."
    }
  }
}
