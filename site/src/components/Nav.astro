---
interface Props {
  active?: 'home' | 'brand' | 'tokens' | 'toolkit' | 'assets' | 'patterns' | 'usage' | 'governance' | 'compliance';
}
const { active = 'home' } = Astro.props;

const links = [
  { href: '/brand', label: 'Brand', key: 'brand' },
  { href: '/tokens', label: 'Tokens', key: 'tokens' },
  { href: '/toolkit', label: 'UI Toolkit', key: 'toolkit' },
  { href: '/assets', label: 'Assets', key: 'assets' },
  { href: '/patterns', label: 'Patterns', key: 'patterns' },
  { href: '/usage', label: 'Usage', key: 'usage' },
  { href: '/governance', label: 'Governance', key: 'governance' },
  { href: '/compliance', label: 'Compliance', key: 'compliance' },
];
---

<header class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__brand" aria-label="Solidigm Design System home">
      <svg class="nav__logo" xmlns="http://www.w3.org/2000/svg" viewBox="25 355 1875 370" aria-hidden="true" focusable="false">
        <polygon fill="#FFFFFF" points="170.83,362.38 34.41,498.81 34.41,584.28 77.4,627.28 246.85,627.28 324.57,549.56 324.57,505.06 233.81,595.81 65.87,595.81 65.87,511.84 183.86,393.85 324.57,393.85 324.57,362.38"/>
        <polygon fill="#FFFFFF" points="217.95,452.72 140.24,530.44 140.24,574.94 230.99,484.19 398.93,484.19 398.93,568.16 280.94,686.15 140.24,686.15 140.24,717.62 293.97,717.62 430.4,581.19 430.4,495.72 387.4,452.72"/>
        <path fill="#FFFFFF" d="M559.89,497.16c0-13.9,11.37-25.26,35.37-25.26c29.24,0,41.73,22.69,41.73,22.69l19.08-19.08c-8.88-14.2-26.47-30.14-60.82-30.14c-40.42,0-65.69,25.26-65.69,53.06c0,63.17,106.12,42.95,106.12,80.85c0,15.16-11.37,26.53-39.16,26.53c-32.67,0-46.75-29.04-46.75-29.04l-19.78,19.78c9.03,16.39,27.83,35.79,66.54,35.79c44.22,0,69.48-25.26,69.48-54.32C666.01,516.11,559.89,535.06,559.89,497.16"/>
        <path fill="#FFFFFF" d="M786.09,445.36c-54.33,0-94.75,40.42-94.75,93.48c0,53.06,40.42,93.48,94.75,93.48c54.32,0,94.74-40.43,94.74-93.48C880.84,485.79,840.41,445.36,786.09,445.36z M786.09,604.54c-37.9,0-64.43-26.53-64.43-65.69c0-39.16,26.53-65.69,64.43-65.69c37.9,0,64.43,26.53,64.43,65.69C850.52,578.01,823.99,604.54,786.09,604.54z"/>
        <polygon fill="#FFFFFF" points="947.78,450.42 918.73,450.42 918.73,588.51 957.18,627.28 1037.48,627.28 1037.48,599.48 947.78,599.48"/>
        <rect fill="#FFFFFF" x="1065.26" y="450.41" width="29.06" height="176.86"/>
        <path fill="#FFFFFF" d="M1199.17,450.41h-20.77l-38.61,38.61v138.25h59.38c55.58,0,94.74-39.16,94.74-88.43C1293.92,489.58,1254.75,450.41,1199.17,450.41z M1199.17,599.48h-30.32V478.21h30.32c39.16,0,64.43,25.27,64.43,60.64C1263.6,574.22,1238.33,599.48,1199.17,599.48z"/>
        <rect fill="#FFFFFF" x="1331.81" y="450.41" width="29.05" height="176.86"/>
        <path fill="#FFFFFF" d="M1522.56,561.59h31.58l-0.04,40.43c0,0-43.75-0.26-60.6-0.26c-37.9,0-64.43-24.97-64.43-62.92c0-39.16,26.53-65.69,64.43-65.69c45.48,0,59.38,36.63,59.38,36.63h29.05c0,0-15.16-64.43-88.43-64.43c-53.06,0-94.75,39.16-94.75,93.48c0,54.33,38.91,90.71,94.75,90.71h51.08l38.61-38.61v-57.15h-60.64V561.59z"/>
        <polygon fill="#FFFFFF" points="1648.94,627.28 1622.42,627.28 1622.42,450.41 1673.27,450.41 1718.43,600.75 1724.75,600.75 1769.91,450.41 1819.49,450.41 1819.49,627.28 1792.96,627.28 1792.96,503.48 1792.96,479.47 1787.59,479.47 1743.69,627.28 1698.22,627.28 1654.32,479.47 1648.95,479.47"/>
        <polygon fill="#FFFFFF" points="1843.27,606.74 1835.15,606.74 1835.15,603 1855.33,603 1855.33,606.74 1847.26,606.74 1847.26,627.28 1843.27,627.28"/>
        <polygon fill="#FFFFFF" points="1858.54,603 1864.71,603 1871.68,623.64 1872.42,623.64 1879.38,603 1885.59,603 1885.59,627.28 1881.6,627.28 1881.6,608.72 1881.78,607.19 1881.57,607.19 1874.85,627.28 1869.25,627.28 1862.53,607.19 1862.36,607.19 1862.53,608.72 1862.53,627.28 1858.54,627.28"/>
      </svg>
      <span class="nav__system-label">Design System</span>
    </a>
    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => (
        <a
          href={l.href}
          class={`nav__link ${active === l.key ? 'nav__link--active' : ''}`}
        >
          {l.label}
        </a>
      ))}
    </nav>
    <a href="https://github.com/solidigm/ai-brand-context" class="btn btn--primary btn--sm nav__cta">
      GitHub ↗
    </a>
    <button
      class="nav__burger"
      id="nav-burger"
      type="button"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <!-- Bars icon -->
      <svg class="icon-bars" width="22" height="16" viewBox="0 0 22 16" fill="none" aria-hidden="true">
        <rect width="22" height="2" rx="1" fill="currentColor"/>
        <rect y="7" width="22" height="2" rx="1" fill="currentColor"/>
        <rect y="14" width="22" height="2" rx="1" fill="currentColor"/>
      </svg>
      <!-- Close icon -->
      <svg class="icon-close" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <line x1="1" y1="1" x2="17" y2="17" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="17" y1="1" x2="1" y2="17" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <!-- Mobile drawer (visible below 990px when open) -->
  <div class="nav__drawer" id="nav-drawer" aria-hidden="true">
    <nav aria-label="Mobile primary">
      {links.map((l) => (
        <a
          href={l.href}
          class={`nav__drawer-link nav__link ${active === l.key ? 'nav__link--active' : ''}`}
        >
          {l.label}
        </a>
      ))}
    </nav>
    <a href="https://github.com/solidigm/ai-brand-context" class="btn btn--ghost btn--sm nav__drawer-cta">
      GitHub ↗
    </a>
  </div>
</header>

<script>
  const burger = document.getElementById('nav-burger') as HTMLButtonElement;
  const drawer = document.getElementById('nav-drawer') as HTMLElement;

  function openMenu() {
    drawer.classList.add('is-open');
    burger.classList.add('is-open');
    burger.setAttribute('aria-expanded', 'true');
    drawer.setAttribute('aria-hidden', 'false');
    burger.setAttribute('aria-label', 'Close navigation');
  }

  function closeMenu() {
    drawer.classList.remove('is-open');
    burger.classList.remove('is-open');
    burger.setAttribute('aria-expanded', 'false');
    drawer.setAttribute('aria-hidden', 'true');
    burger.setAttribute('aria-label', 'Open navigation');
  }

  burger.addEventListener('click', () => {
    drawer.classList.contains('is-open') ? closeMenu() : openMenu();
  });

  drawer.querySelectorAll('.nav__drawer-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') {
      closeMenu();
      burger.focus();
    }
  });

  document.addEventListener('click', (e: Event) => {
    const nav = burger.closest('.nav') as HTMLElement;
    if (nav && !nav.contains(e.target as Node)) closeMenu();
  });
</script>
