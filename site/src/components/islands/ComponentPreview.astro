---
interface Props {
  title?: string;
  html: string;
}
const { title, html } = Astro.props;
const id = `cp-${Math.random().toString(36).slice(2, 8)}`;
---
<div class="component-preview">
  {title && <div class="component-preview__head">{title}</div>}
  <div class="component-preview__tabs">
    <button class="component-preview__tab is-active" data-tab="preview" data-target={id}>Preview</button>
    <button class="component-preview__tab" data-tab="code" data-target={id}>HTML</button>
  </div>
  <div class="component-preview__panel" data-panel="preview" data-id={id}>
    <div class="component-preview__stage" set:html={html} />
  </div>
  <div class="component-preview__panel" data-panel="code" data-id={id} hidden>
    <pre><code>{html}</code></pre>
  </div>
</div>

<style>
.component-preview {
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: var(--border-radius-md, 16px);
  overflow: hidden;
  background: #fff;
  margin: var(--space-5, 20px) 0;
}
.component-preview__head {
  padding: 12px 16px;
  font-size: 12px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--color-neutral-600);
  border-bottom: 1px solid rgba(0,0,0,0.06);
  background: var(--color-neutral-50);
}
.component-preview__tabs {
  display: flex;
  gap: 0;
  border-bottom: 1px solid rgba(0,0,0,0.06);
  background: #fff;
}
.component-preview__tab {
  background: none;
  border: 0;
  padding: 10px 18px;
  font: inherit;
  font-size: 12px;
  font-weight: 500;
  color: var(--color-neutral-600);
  cursor: pointer;
  border-bottom: 2px solid transparent;
}
.component-preview__tab.is-active {
  color: var(--color-purple-500);
  border-bottom-color: var(--color-purple-500);
}
.component-preview__stage {
  padding: var(--space-8, 32px);
  background:
    linear-gradient(45deg, rgba(0,0,0,0.02) 25%, transparent 25%),
    linear-gradient(-45deg, rgba(0,0,0,0.02) 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, rgba(0,0,0,0.02) 75%),
    linear-gradient(-45deg, transparent 75%, rgba(0,0,0,0.02) 75%);
  background-size: 20px 20px;
  background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 120px;
  flex-wrap: wrap;
  gap: 16px;
}
.component-preview__panel pre { margin: 0; border-radius: 0; }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.component-preview__tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = tab.dataset.target;
      const which = tab.dataset.tab;
      document.querySelectorAll<HTMLButtonElement>(`.component-preview__tab[data-target="${id}"]`).forEach((t) => {
        t.classList.toggle('is-active', t.dataset.tab === which);
      });
      document.querySelectorAll<HTMLElement>(`[data-id="${id}"]`).forEach((p) => {
        p.hidden = p.dataset.panel !== which;
      });
    });
  });
</script>
