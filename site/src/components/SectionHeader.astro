---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  align?: 'left' | 'center';
  theme?: 'light' | 'dark' | 'purple';
}
const { eyebrow, title, lede, align = 'left', theme = 'light' } = Astro.props;
---
<div class={`section-header${align === 'center' ? ' section-header--center' : ''}`}>
  {eyebrow && (
    <span class={`eyebrow ${theme !== 'light' ? 'eyebrow--dark' : ''}`}>{eyebrow}</span>
  )}
  <h2 class="section-title">{title}</h2>
  {lede && <p class="section-lede">{lede}</p>}
</div>

<style>
.section-header {
  max-width: 860px;
  margin-bottom: var(--space-10);
}
.section-header--center {
  text-align: center;
  max-width: 780px;
  margin-left: auto;
  margin-right: auto;
}
.section-header--center .section-lede {
  margin-left: auto;
  margin-right: auto;
}
</style>
