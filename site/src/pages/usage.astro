---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHeader from '~/components/SectionHeader.astro';
import CodeBlock from '~/components/CodeBlock.astro';
---
<BaseLayout title="How to use" description="Install design tokens, use the UI toolkit, consume the MCP server, and integrate Solidigm brand assets into your project." activeNav="usage">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">How to use</span>
      <h1 class="page-hero__title">Find your path.</h1>
      <p class="page-hero__lede">
        Three audiences, three guides. Jump to the one that fits — come back when you need
        the other view.
      </p>
    </div>
  </section>

  <!-- Tab switcher -->
  <section class="section">
    <div class="container">
      <div class="audience-tabs" role="tablist">
        <button class="audience-tab is-active" data-aud="designers" role="tab">For Designers</button>
        <button class="audience-tab" data-aud="engineers" role="tab">For Engineers</button>
        <button class="audience-tab" data-aud="business" role="tab">For Business</button>
        <button class="audience-tab" data-aud="agents" role="tab">For AI Agents</button>
      </div>

      <!-- DESIGNERS -->
      <div id="designers" class="audience-panel" data-aud-panel="designers">
        <SectionHeader
          eyebrow="For Designers"
          title="Design in Figma. Stay in system."
          lede="The Solidigm Design System 3.0 Figma library is your starting point. Tokens, components, and the Brand Angle are all there."
        />
        <div class="grid grid--2">
          <div class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">1. Open the library</h3>
            <p class="text-small muted">Enable the <a href="https://www.figma.com/design/Ei8AT6lR0173XP1v8kY3JJ">Solidigm Design System 3.0</a> file as a team library in your Figma workspace.</p>
          </div>
          <div class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">2. Use variables, not raw values</h3>
            <p class="text-small muted">Every fill, text style, and spacing is exposed as a Figma variable. Never hardcode a hex or pixel value.</p>
          </div>
          <div class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">3. Compose from components</h3>
            <p class="text-small muted">Buttons, cards, heros — start from a library component. Detach only when the variant doesn't exist yet.</p>
          </div>
          <div class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">4. Respect Brand Angle rules</h3>
            <p class="text-small muted">The Brand Angle (45°/90° crop of the mark) has <a href="/brand">approved color combinations</a>. Check before shipping.</p>
          </div>
        </div>
      </div>

      <!-- ENGINEERS -->
      <div id="engineers" class="audience-panel" data-aud-panel="engineers" hidden>
        <SectionHeader
          eyebrow="For Engineers"
          title="Install, import, ship."
          lede="Pick the format that matches your stack. One source of truth, six output formats."
        />
        <CodeBlock lang="bash" code={`npm install @solidigm/brand-tokens`} />
        <div class="grid grid--2" style="margin-top: var(--space-5, 20px);">
          <a href="/tokens/usage#css" class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">CSS variables</h3>
            <p class="text-small muted">One <code>@import</code>. Every token available as a custom property.</p>
          </a>
          <a href="/tokens/usage#scss" class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">Sass / SCSS</h3>
            <p class="text-small muted">Use tokens as Sass variables. Perfect for existing SCSS codebases.</p>
          </a>
          <a href="/tokens/usage#js" class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">JavaScript / TypeScript</h3>
            <p class="text-small muted">Fully-typed token objects. Great for React, Vue, Svelte, and theming systems.</p>
          </a>
          <a href="/tokens/usage#tailwind" class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">Tailwind preset</h3>
            <p class="text-small muted">Drop-in preset. Tailwind utilities automatically use Solidigm tokens.</p>
          </a>
          <a href="/tokens/usage#eslint" class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">ESLint plugin</h3>
            <p class="text-small muted">Block off-brand colors at PR time. Auto-suggests the right token.</p>
          </a>
          <a href="/toolkit" class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">Plain CSS toolkit</h3>
            <p class="text-small muted">No build step? Use <code>ui-toolkit.min.css</code> via a <code>&lt;link&gt;</code> tag.</p>
          </a>
        </div>
        <div class="card" style="margin-top: var(--space-6, 24px); border-left: 4px solid var(--color-purple-500);">
          <strong style="color: var(--color-purple-600);">AEM &amp; client libraries</strong>
          <p class="text-small muted" style="margin-top:8px;">
            For Adobe Experience Manager, package the UI toolkit CSS as a client library
            (<code>etc.clientlibs</code>) and reference it in your page template. The CSS is
            self-contained — no JS dependencies.
          </p>
        </div>
      </div>

      <!-- BUSINESS -->
      <div id="business" class="audience-panel" data-aud-panel="business" hidden>
        <SectionHeader
          eyebrow="For Business"
          title="Request, review, stay on-brand."
          lede="You don't need to write code to use the system. These are the moments you'll interact with it."
        />
        <div class="grid grid--2">
          <div class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">How do I request a new component?</h3>
            <p class="text-small muted">Open a GitHub issue on the <a href="https://github.com/solidigm/ai-brand-context">design-system repo</a> with use case, example, and audience. A designer + engineer will triage it.</p>
          </div>
          <div class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">What stays on-brand without asking?</h3>
            <p class="text-small muted">Any combination using our 14 colors, Sora family, and the 17-step spacing scale — as long as accents aren't dominant.</p>
          </div>
          <div class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">What requires approval?</h3>
            <p class="text-small muted">Electric Teal and Electric Pink in dominant roles. Logo variants beyond the standard set. Net-new typefaces or iconography.</p>
          </div>
          <div class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">Brand compliance checklist</h3>
            <ul class="text-small muted" style="margin:8px 0 0; padding-left:18px;">
              <li>Uses tokens — not hardcoded values</li>
              <li>Left-aligned body text</li>
              <li>One primary action per view</li>
              <li>TM in logo, title-case headlines</li>
              <li>Accents used sparingly</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- AI AGENTS -->
      <div id="agents" class="audience-panel" data-aud-panel="agents" hidden>
        <SectionHeader
          eyebrow="For AI Agents"
          title="One MCP. Every brand answer."
          lede="The Solidigm Brand MCP server gives agents (Claude, Cursor, Copilot, ChatGPT with MCP) authoritative access to tokens, guidelines, UI toolkit rules, and the official brand asset library."
        />

        <div class="grid grid--2">
          <div class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">Quick install — VS Code Copilot</h3>
            <p class="text-small muted">The workspace ships with <code>.vscode/mcp.json</code> pre-wired. Open this repo in VS Code with Copilot enabled and the <strong>solidigm-brand</strong> server is available.</p>
          </div>
          <div class="card">
            <h3 style="margin:0 0 8px; font-size:18px;">Claude Desktop / Cursor</h3>
            <p class="text-small muted">Add an HTTP MCP entry pointing at the internal server URL. See <a href="https://github.com/solidigm/ai-brand-context/blob/main/brand_mcp/README.md">brand_mcp/README.md</a> for exact JSON.</p>
          </div>
        </div>

        <h3 class="text-h5" style="margin-top:32px;">Token tools</h3>
        <div class="grid grid--2">
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>get_design_tokens</code></h4>
            <p class="text-small muted" style="margin:0;">All tokens or filter by category: <code>colors</code>, <code>typography</code>, <code>space</code>, <code>motion</code>, <code>elevation</code>, <code>breakpoints</code>, <code>icons</code>, and more.</p>
          </div>
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>get_color</code></h4>
            <p class="text-small muted" style="margin:0;">Look up a color by name ("Solidigm Purple", "Electric Teal"). Fuzzy-matches common aliases.</p>
          </div>
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>get_spacing</code></h4>
            <p class="text-small muted" style="margin:0;">Return a single spacing step value ("4" → "16px") or dump the full 17-step scale.</p>
          </div>
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>get_breakpoints</code></h4>
            <p class="text-small muted" style="margin:0;">Canonical breakpoint widths and container-max-width values for responsive layouts.</p>
          </div>
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>get_motion</code></h4>
            <p class="text-small muted" style="margin:0;">Animation duration steps and cubic-bezier easing tokens (ease, ease-in, ease-out, spring).</p>
          </div>
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>get_icon</code></h4>
            <p class="text-small muted" style="margin:0;">SVG spec for any icon — viewBox, asset path, size bindings, theme and animation rules.</p>
          </div>
        </div>

        <h3 class="text-h5" style="margin-top:32px;">Guidelines &amp; copy tools</h3>
        <div class="grid grid--2">
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>get_brand_guidelines</code></h4>
            <p class="text-small muted" style="margin:0;">Full brand guidelines or a specific topic section (voice, logo, typography, color usage…).</p>
          </div>
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>get_ui_toolkit_class</code></h4>
            <p class="text-small muted" style="margin:0;">Return CSS rules for any <code>.tk-*</code> or <code>.u-*</code> utility class from the UI toolkit.</p>
          </div>
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>get_brand_context</code></h4>
            <p class="text-small muted" style="margin:0;">Scoped brand context keyed by platform + task — ideal for injecting into a generation prompt.</p>
          </div>
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>get_brand_system_prompt</code></h4>
            <p class="text-small muted" style="margin:0;">Drop-in system prompt pre-loaded with current brand rules for brand-aware LLM calls.</p>
          </div>
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>validate_brand_output</code></h4>
            <p class="text-small muted" style="margin:0;">Run generated copy or markup through the 16 quality gates before publishing.</p>
          </div>
        </div>

        <h3 class="text-h5" style="margin-top:32px;">Asset tools</h3>
        <div class="grid grid--2">
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>list_assets</code></h4>
            <p class="text-small muted" style="margin:0;">Unified manifest of local + SharePoint brand assets — filterable by category, color, variant, and resolution.</p>
          </div>
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>get_asset</code> / <code>get_logo</code></h4>
            <p class="text-small muted" style="margin:0;">Resolve one asset by name or path (<code>get_asset</code>), or resolve a specific logo variant/color/format (<code>get_logo</code>).</p>
          </div>
          <div class="card">
            <h4 style="margin:0 0 4px; font-size:14px; font-weight:600;"><code>search_brand_source_documents</code></h4>
            <p class="text-small muted" style="margin:0;">SharePoint-only — recursively search the official Solidigm brand library (requires Entra auth).</p>
          </div>
        </div>

        <h3 class="text-h5" style="margin-top:32px;">Resources (<code>read_resource</code>)</h3>
        <ul class="text-small muted" style="line-height:1.9;">
          <li><code>brand://tokens/colors</code> — all color tokens, W3C DTCG format</li>
          <li><code>brand://tokens/typography</code> — all type styles (desktop + mobile)</li>
          <li><code>brand://tokens/space</code> — full 17-step spacing scale</li>
          <li><code>brand://tokens/motion</code> — duration steps and easing curves</li>
          <li><code>brand://tokens/icons</code> — icon catalog with SVG specs</li>
          <li><code>brand://guidelines/main</code> — full brand guidelines markdown</li>
          <li><code>brand://toolkit/css</code> — the UI toolkit CSS source</li>
          <li><code>brand://assets/manifest</code> — JSON manifest of every local asset</li>
        </ul>

        <p class="text-small muted" style="margin-top:24px;">
          See the <a href="/governance#mcp">governance page</a> for MCP contribution rules, and <a href="https://github.com/solidigm/ai-brand-context/blob/main/docs/architecture.md">docs/architecture.md</a> for the system diagram.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.audience-tabs {
  display: flex;
  gap: 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
  margin-bottom: var(--space-8);
  flex-wrap: wrap;
}
.audience-tab {
  background: transparent;
  border: 0;
  border-bottom: 2px solid transparent;
  padding: var(--space-3) var(--space-5);
  font: inherit;
  font-size: 10px;
  font-weight: var(--font-weight-semibold);
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  color: var(--medium-gray);
  transition: color var(--dur-fast), border-color var(--dur-fast);
  margin-bottom: -1px;
}
.audience-tab:hover { color: var(--solidigm-purple); }
.audience-tab.is-active {
  color: var(--solidigm-purple);
  border-bottom-color: var(--solidigm-purple);
}
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.audience-tab');
  const panels = document.querySelectorAll<HTMLElement>('[data-aud-panel]');
  const hash = window.location.hash.replace('#', '');
  const activate = (aud: string) => {
    tabs.forEach((t) => t.classList.toggle('is-active', t.dataset.aud === aud));
    panels.forEach((p) => {
      p.hidden = p.dataset.audPanel !== aud;
    });
  };
  if (hash && ['designers', 'engineers', 'business', 'agents'].includes(hash)) activate(hash);
  tabs.forEach((t) => {
    t.addEventListener('click', () => {
      if (t.dataset.aud) {
        activate(t.dataset.aud);
        history.replaceState(null, '', `#${t.dataset.aud}`);
      }
    });
  });
</script>
