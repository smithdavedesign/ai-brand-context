---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHeader from '~/components/SectionHeader.astro';
---
<BaseLayout
  title="Brand Compliance"
  description="Check copy, markup, or content against Solidigm brand quality gates using the live MCP validator or the AI brand assistant."
  activeNav="compliance"
>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Compliance</span>
      <h1 class="page-hero__title">Check before you ship.</h1>
      <p class="page-hero__lede">
        Two tools, one goal: keep every surface on-brand. The validator runs
        your copy or markup through 16 mechanical quality gates instantly.
        The brand assistant handles the nuanced questions.
      </p>
    </div>
  </section>

  <!-- ─── LIVE MCP VALIDATOR ─────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Quality gates"
        title="Validate copy or markup."
        body="Paste anything — an email subject, a headline, a chunk of HTML — and see exactly which brand rules it passes or fails."
      />

      <div class="compliance-validator">
        <div class="compliance-validator__input-area">
          <label for="validate-input" class="compliance-validator__label">
            Content to validate
          </label>
          <textarea
            id="validate-input"
            class="compliance-validator__textarea"
            placeholder="Paste copy, HTML, or markdown here…&#10;&#10;Example:&#10;Welcome to the revolutionary future of storage. Solidigm® DC PS1010 offers game-changing performance."
            rows="8"
          ></textarea>
          <div class="compliance-validator__controls">
            <select id="validate-platform" class="compliance-validator__select">
              <option value="web">Platform: Web</option>
              <option value="email">Platform: Email</option>
              <option value="presentation">Platform: Presentation</option>
              <option value="social">Platform: Social</option>
              <option value="print">Platform: Print</option>
            </select>
            <button id="validate-btn" class="btn btn--primary" type="button">
              Run check
            </button>
          </div>
          <p class="compliance-validator__note text-small muted">
            Calls the Solidigm Brand MCP server at
            <code>http://localhost:8080/api/validate</code>. Start the MCP
            server locally before using this tool.
          </p>
        </div>

        <div class="compliance-validator__results" id="validate-results" hidden>
          <div class="compliance-results-inner" id="validate-results-inner"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── QUALITY GATES REFERENCE ───────────────────────────────────── -->
  <section class="section section--light">
    <div class="container">
      <SectionHeader
        eyebrow="16 gates"
        title="What gets checked."
      />
      <div class="grid grid--3">
        <div class="card">
          <h3 style="margin:0 0 8px; font-size:15px; font-weight:600;">Trademark</h3>
          <p class="text-small muted" style="margin:0;">First mention uses <code>Solidigm™</code>. Never <code>®</code>. Product names follow same rule.</p>
        </div>
        <div class="card">
          <h3 style="margin:0 0 8px; font-size:15px; font-weight:600;">Color palette</h3>
          <p class="text-small muted" style="margin:0;">Only the 14 approved hex values. Accents limited to ≤ 10% of any composition.</p>
        </div>
        <div class="card">
          <h3 style="margin:0 0 8px; font-size:15px; font-weight:600;">Typography</h3>
          <p class="text-small muted" style="margin:0;">Sora for headlines, Noto Sans for body. No Arial, Helvetica, Roboto, or system-ui alone.</p>
        </div>
        <div class="card">
          <h3 style="margin:0 0 8px; font-size:15px; font-weight:600;">Heading case</h3>
          <p class="text-small muted" style="margin:0;">Title case or sentence case. Never all-caps. No <code>text-transform: uppercase</code> on headings.</p>
        </div>
        <div class="card">
          <h3 style="margin:0 0 8px; font-size:15px; font-weight:600;">Voice</h3>
          <p class="text-small muted" style="margin:0;">No "revolutionary", "game-changing", "disruptor". Concrete numbers over marketing superlatives.</p>
        </div>
        <div class="card">
          <h3 style="margin:0 0 8px; font-size:15px; font-weight:600;">Accent ratio</h3>
          <p class="text-small muted" style="margin:0;">Electric Teal, Electric Pink, and Orange are emphasis-only. Not for backgrounds or borders.</p>
        </div>
      </div>
      <p style="margin-top: 24px;" class="text-small muted">
        Full gate definitions live in <code>brand/quality-gates.yaml</code> in the repo.
      </p>
    </div>
  </section>

  <!-- ─── BRAND ASSISTANT BOT (Teams) ────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Brand assistant"
        title="Ask the brand bot."
        body="The Solidigm brand assistant handles questions the validator can't: nuanced voice questions, logo usage guidance, asset recommendations, and more."
      />

      <div class="bot-teams-card">
        <div class="bot-teams-card__inner">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true" class="bot-teams-card__icon">
            <rect width="40" height="40" rx="8" fill="#4f00b5"/>
            <path d="M26.5 14.5h-4v-2a2.5 2.5 0 0 0-5 0v2h-4A1.5 1.5 0 0 0 12 16v10a1.5 1.5 0 0 0 1.5 1.5h13A1.5 1.5 0 0 0 28 26V16a1.5 1.5 0 0 0-1.5-1.5ZM19 12.5a1 1 0 1 1 2 0v2h-2v-2Zm1 14a4.5 4.5 0 0 1-4.5-4.5h2a2.5 2.5 0 0 0 5 0h2A4.5 4.5 0 0 1 20 26.5Z" fill="#fff"/>
          </svg>
          <h3 class="bot-teams-card__title">Available in Microsoft Teams</h3>
          <p class="text-small muted bot-teams-card__desc">
            The brand assistant runs inside Teams with your Solidigm Microsoft
            account. Ask about trademark usage, logo guidance, compliant
            headlines, and more.
          </p>
          <div class="bot-teams-card__actions">
            <a
              href="https://teams.microsoft.com/l/app/?titleId=T_6c83d448-1f15-0d91-6c19-73ff73a83268"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--primary"
            >
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" style="margin-right:8px; vertical-align: -4px;">
                <path d="M17.42 6.76a1.71 1.71 0 1 0 0-3.42 1.71 1.71 0 0 0 0 3.42Z" fill="currentColor"/>
                <path d="M18.56 7.9h-2.97a1.89 1.89 0 0 1 .27.96v4.28a2.62 2.62 0 0 1-.08.62H17.7c.48 0 .86-.39.86-.86V8.76a.86.86 0 0 0-.86-.86h.86Z" fill="currentColor"/>
                <path d="M13.14 5.9a2.29 2.29 0 1 0 0-4.57 2.29 2.29 0 0 0 0 4.57Z" fill="currentColor"/>
                <path d="M15.43 7.05h-4.58a1.14 1.14 0 0 0-1.14 1.14v5.14a2.86 2.86 0 0 0 5.71 0V8.19c0-.63-.44-1.14-.99-1.14Z" fill="currentColor"/>
                <path d="M8.86 6.47a2.86 2.86 0 1 0 0-5.71 2.86 2.86 0 0 0 0 5.71Z" fill="currentColor"/>
                <path d="M11.71 7.62H6a1.14 1.14 0 0 0-1.14 1.14v5.71a3.43 3.43 0 0 0 6.86 0V8.76c0-.63-.44-1.14-1.01-1.14Z" fill="currentColor"/>
              </svg>
              Open in Teams
            </a>
          </div>
          <p class="text-small muted bot-teams-card__note">
            Requires a Solidigm Microsoft account. If you don't see the bot,
            ask your Teams admin to enable the Copilot Studio agent channel.
          </p>
        </div>
      </div>

      <details class="bot-examples" style="margin-top: 20px;">
        <summary class="text-small" style="cursor:pointer; font-weight:600; color: var(--solidigm-color-solidigm-purple, #4f00b5);">
          Example questions you can ask
        </summary>
        <ul class="text-small muted" style="margin-top:8px; padding-left:20px; line-height:1.9;">
          <li>"What's the correct trademark usage for our product names?"</li>
          <li>"Which logo should I use on a dark background?"</li>
          <li>"Write a compliant press release headline."</li>
          <li>"Can I use Electric Teal as a background color?"</li>
          <li>"What are the approved fonts for PowerPoint?"</li>
        </ul>
      </details>
    </div>
  </section>

  <!-- ─── FOR DEVELOPERS ────────────────────────────────────────────── -->
  <section class="section section--light">
    <div class="container">
      <SectionHeader
        eyebrow="For developers"
        title="Automate compliance in CI."
        body="The brand-compliance Skill audits a fully built site directory and emits a letter-graded markdown report. Wire it into your PR checks and compliance becomes a gate, not an afterthought."
      />
      <div class="grid grid--2">
        <div class="card">
          <h3 style="margin:0 0 8px; font-size:15px; font-weight:600;">Run the audit</h3>
          <pre class="code-block" style="margin:0; font-size:13px;"><code>node .github/skills/brand-compliance/scripts/audit-pages.mjs</code></pre>
          <p class="text-small muted" style="margin:8px 0 0;">Scans <code>site/dist/</code> after a production build. Target grade ≥ B before merging.</p>
        </div>
        <!-- brand-audit:exempt -->
        <div class="card">
          <h3 style="margin:0 0 8px; font-size:15px; font-weight:600;">API validation</h3>
          <pre class="code-block" style="margin:0; font-size:13px;"><code>POST http://localhost:8080/api/validate
Content-Type: application/json

&#123;"content": "...", "platform": "web"&#125;</code></pre>
          <p class="text-small muted" style="margin:8px 0 0;">Returns <code>&#123;"pass": true, "score": 98, "violations": []&#125;</code>.</p>
        </div>
        <!-- /brand-audit:exempt -->
      </div>
    </div>
  </section>

</BaseLayout>

<!-- ─── VALIDATOR script ─────────────────────────────────────────────── -->
<script is:inline>
  const MCP_VALIDATE_URL = 'http://localhost:8080/api/validate';

  const runBtn     = document.getElementById('validate-btn');
  const inputEl    = document.getElementById('validate-input');
  const platformEl = document.getElementById('validate-platform');
  const resultsEl  = document.getElementById('validate-results');
  const innerEl    = document.getElementById('validate-results-inner');

  function badge(pass) {
    return pass
      ? '<span class="compliance-badge compliance-badge--pass">Pass</span>'
      : '<span class="compliance-badge compliance-badge--fail">Fail</span>';
  }

  function renderResults(data) {
    const score = typeof data.score === 'number' ? data.score : null;
    const violations = Array.isArray(data.violations) ? data.violations : [];
    const passed = data.pass === true;

    let html = `
      <div class="compliance-summary ${passed ? 'compliance-summary--pass' : 'compliance-summary--fail'}">
        <div class="compliance-summary__status">
          ${badge(passed)}
          ${score !== null ? `<span class="compliance-summary__score">Score: ${score}/100</span>` : ''}
        </div>
        <p class="compliance-summary__message text-small">${
          passed
            ? 'All quality gates passed. This content is on-brand.'
            : `${violations.length} violation${violations.length !== 1 ? 's' : ''} found.`
        }</p>
      </div>`;

    if (violations.length) {
      html += '<ul class="compliance-violations">';
      for (const v of violations) {
        html += `
          <li class="compliance-violation">
            <span class="compliance-violation__gate">${v.gate ?? v.rule ?? 'Rule'}</span>
            <span class="compliance-violation__detail">${v.message ?? v.detail ?? v.description ?? JSON.stringify(v)}</span>
          </li>`;
      }
      html += '</ul>';
    }

    innerEl.innerHTML = html;
    resultsEl.hidden = false;
  }

  function renderError(msg) {
    innerEl.innerHTML = `<div class="compliance-summary compliance-summary--fail">
      <p class="text-small" style="margin:0;">${msg}</p>
    </div>`;
    resultsEl.hidden = false;
  }

  runBtn.addEventListener('click', async () => {
    const content = inputEl.value.trim();
    if (!content) return;

    runBtn.disabled = true;
    runBtn.textContent = 'Checking…';
    resultsEl.hidden = true;

    try {
      const res = await fetch(MCP_VALIDATE_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content, platform: platformEl.value }),
      });
      if (!res.ok) throw new Error(`MCP server returned ${res.status}`);
      const data = await res.json();
      renderResults(data);
    } catch (err) {
      renderError(
        'Could not reach the MCP server at <code>localhost:8080</code>. ' +
        'Please start it with: <code>cd brand_mcp && source .venv/bin/activate && python -m brand_mcp.server</code>'
      );
    } finally {
      runBtn.disabled = false;
      runBtn.textContent = 'Run check';
    }
  });
</script>

<style>
  /* ── Validator layout ───────────────────────────────────────────────────── */
  .compliance-validator {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }
  @media (max-width: 768px) {
    .compliance-validator { grid-template-columns: 1fr; }
  }

  .compliance-validator__label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--solidigm-color-medium-gray, #52514f);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .compliance-validator__textarea {
    width: 100%;
    min-height: 200px;
    padding: 14px 16px;
    border: 1px solid var(--solidigm-color-gray, #a5a29d);
    border-radius: 8px;
    font-family: 'Noto Sans', system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.6;
    resize: vertical;
    box-sizing: border-box;
    background: #fff;
    color: var(--solidigm-color-dark-grey, #21201f);
    transition: border-color 0.15s;
  }
  .compliance-validator__textarea:focus {
    outline: none;
    border-color: var(--solidigm-color-solidigm-purple, #4f00b5);
    box-shadow: 0 0 0 3px rgba(79, 0, 181, 0.12);
  }

  .compliance-validator__controls {
    display: flex;
    gap: 12px;
    margin-top: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .compliance-validator__select {
    padding: 8px 12px;
    border: 1px solid var(--solidigm-color-gray, #a5a29d);
    border-radius: 6px;
    font-family: 'Noto Sans', system-ui, sans-serif;
    font-size: 13px;
    background: #fff;
    color: var(--solidigm-color-dark-grey, #21201f);
    cursor: pointer;
  }

  .compliance-validator__note {
    margin-top: 10px;
    margin-bottom: 0;
  }

  .compliance-validator__results {
    background: var(--solidigm-color-light-gray, #f5f3f1);
    border: 1px solid #e0ddd9;
    border-radius: 10px;
    padding: 20px;
    min-height: 200px;
  }

  /* ── Result states ───────────────────────────────────────────────────────── */
  .compliance-summary {
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 16px;
  }
  .compliance-summary--pass {
    background: rgba(0, 83, 32, 0.07);
    border: 1px solid rgba(0, 83, 32, 0.2);
  }
  .compliance-summary--fail {
    background: rgba(181, 0, 36, 0.07);
    border: 1px solid rgba(181, 0, 36, 0.2);
  }
  .compliance-summary__status {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }
  .compliance-summary__score {
    font-size: 13px;
    font-weight: 600;
    color: var(--solidigm-color-dark-grey, #21201f);
  }
  .compliance-summary__message {
    margin: 0;
  }

  .compliance-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .compliance-badge--pass {
    background: rgba(0, 83, 32, 0.12);
    color: #005320;
  }
  .compliance-badge--fail {
    background: rgba(181, 0, 36, 0.12);
    color: #b50024;
  }

  .compliance-violations {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .compliance-violation {
    padding: 10px 14px;
    background: #fff;
    border: 1px solid #e0ddd9;
    border-radius: 6px;
    display: flex;
    gap: 12px;
    align-items: baseline;
    font-size: 13px;
  }
  .compliance-violation__gate {
    font-weight: 600;
    color: var(--solidigm-color-solidigm-purple, #4f00b5);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .compliance-violation__detail {
    color: var(--solidigm-color-dark-grey, #21201f);
    line-height: 1.5;
  }

  /* ── Teams bot card ───────────────────────────────────────────────────── */
  .bot-teams-card {
    border: 1px solid #e0ddd9;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
  }
  .bot-teams-card__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 48px 40px;
  }
  .bot-teams-card__icon {
    margin-bottom: 20px;
  }
  .bot-teams-card__title {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
  }
  .bot-teams-card__desc {
    margin: 0 0 24px;
    max-width: 420px;
  }
  .bot-teams-card__actions {
    margin-bottom: 16px;
  }
  .bot-teams-card__note {
    margin: 0;
    font-size: 12px;
    opacity: 0.7;
  }

  /* ── Code block ─────────────────────────────────────────────────────────── */
  .code-block {
    background: var(--solidigm-color-ultra-dark-purple, #160231);
    color: #e8e8e8;
    border-radius: 8px;
    padding: 14px 16px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.6;
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
  }
</style>
