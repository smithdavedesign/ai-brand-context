---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHeader from '~/components/SectionHeader.astro';

// Default MCP server URL can be overridden at build time via PUBLIC_MCP_URL.
const mcpUrl = import.meta.env.PUBLIC_MCP_URL || 'http://localhost:8080';

const quickDownloads = [
  {
    label: 'Standard Logo — Purple',
    filename: 'solidigm-logo-purple.svg',
    url: '/assets/logo/standard/purple/solidigm-logo-purple.svg',
    hint: 'SVG · Light backgrounds',
    dark: false,
  },
  {
    label: 'Standard Logo — White',
    filename: 'standard-logo-white-tm-1920x1080.png',
    url: '/assets/logo/standard/white/standard-logo-white-tm-1920x1080.png',
    hint: 'PNG · Dark backgrounds',
    dark: true,
  },
  {
    label: 'S Mark — Purple',
    filename: 's-mark-purple-tm-1920x1080.png',
    url: '/assets/logo/s-mark/purple/s-mark-purple-tm-1920x1080.png',
    hint: 'PNG · Icon usage',
    dark: false,
  },
  {
    label: 'S Mark — White',
    filename: 's-mark-white-tm-1920x1080.png',
    url: '/assets/logo/s-mark/white/s-mark-white-tm-1920x1080.png',
    hint: 'PNG · Icon on dark',
    dark: true,
  },
  {
    label: 'Purple Icons Pack',
    filename: 'solidigm-purple-ppt-icons.pptx',
    url: '/assets/docs/solidigm-purple-ppt-icons.pptx',
    hint: 'PPTX · 80+ icons',
    dark: false,
    format: 'PPTX',
  },
  {
    label: 'Brand Guidelines',
    filename: 'solidigm-consolidated-brand-guidelines_revjan26.pdf',
    url: '/assets/docs/solidigm-consolidated-brand-guidelines_revjan26.pdf',
    hint: 'PDF · Jan 2026',
    dark: false,
    format: 'PDF',
  },
];
---

<BaseLayout
  title="Brand Assets"
  description="Browse, filter, and download official Solidigm brand assets — logos, illustrations, and brand guideline documents."
  activeNav="assets"
>
  <section class="section">
    <div class="container">
    <SectionHeader
      eyebrow="Assets"
      title="Brand asset library"
      lede="Every official Solidigm logo, illustration, and guideline document in one searchable place. Local assets load instantly; SharePoint assets require Solidigm authentication."
    />

    <!-- Quick downloads: no MCP required -->
    <div class="quick-dl">
      <h3 class="quick-dl__heading">Quick downloads</h3>
      <div class="quick-dl__grid">
        {quickDownloads.map((item) => (
          <a
            class={`quick-dl__item${item.dark ? ' quick-dl__item--dark' : ''}`}
            href={item.url}
            download={item.filename}
          >
            <div class="quick-dl__preview">
              {item.format
                ? <span class="quick-dl__fmt">{item.format}</span>
                : <img src={item.url} alt={item.label} loading="lazy" />}
            </div>
            <div class="quick-dl__info">
              <span class="quick-dl__label">{item.label}</span>
              <span class="quick-dl__hint">{item.hint}</span>
            </div>
            <span class="quick-dl__action">↓</span>
          </a>
        ))}
      </div>
    </div>

    <div class="asset-controls" role="toolbar" aria-label="Asset filters">
      <!-- Always-visible row -->
      <div class="asset-controls__primary">
        <label class="asset-field">
          <span>Category</span>
          <select id="assetCategory">
            <option value="">All</option>
            <option value="logo">Logos</option>
            <option value="illustration">Illustrations</option>
            <option value="icon">Icons</option>
            <option value="image">Images</option>
            <option value="template">Templates</option>
            <option value="product-render">Product Renders</option>
            <option value="doc">Documents</option>
          </select>
        </label>

        <label class="asset-field asset-field--grow">
          <span>Search</span>
          <input id="assetSearch" type="search" placeholder="Filter by filename…" />
        </label>

        <button type="button" class="asset-reset" id="assetReset" hidden aria-label="Clear filters">Reset</button>
      </div>

      <!-- Sub-filters row — shown only when a specific category is active -->
      <div class="asset-controls__subfilters" id="assetSubfilters" hidden>

        <!-- Logo filters -->
        <label class="asset-field" id="colorField" hidden>
          <span>Color</span>
          <select id="assetColor">
            <option value="">Any</option>
            <option value="purple">Purple</option>
            <option value="black">Black</option>
            <option value="blue">Blue</option>
            <option value="white">White</option>
          </select>
        </label>

        <label class="asset-field" id="variantField" hidden>
          <span>Variant</span>
          <select id="assetVariant">
            <option value="">Any</option>
            <option value="standard">Standard</option>
            <option value="stacked">Stacked</option>
            <option value="wordmark">Wordmark</option>
            <option value="s-mark">S Mark</option>
          </select>
        </label>

        <label class="asset-field" id="logoFormatField" hidden>
          <span>Format</span>
          <select id="assetLogoFormat">
            <option value="">Any</option>
            <option value="png">PNG</option>
            <option value="svg">SVG</option>
            <option value="eps">EPS</option>
          </select>
        </label>

        <!-- Image filters -->
        <label class="asset-field" id="imageSubcatField" hidden>
          <span>Subject</span>
          <select id="assetImageSubcat">
            <option value="">Any</option>
            <option value="01. People_Partnerships_Groups">People / Partnerships</option>
            <option value="02. Techs Impact">Tech’s Impact</option>
            <option value="03. People_Industries">People / Industries</option>
            <option value="04. People_Problem Solvers">Problem Solvers</option>
            <option value="05. Tech in Use">Tech in Use</option>
            <option value="06. Data Center_People">Data Center / People</option>
            <option value="07. Data Center">Data Center</option>
            <option value="08. Texture">Texture</option>
            <option value="09 - Abstract">Abstract</option>
          </select>
        </label>

        <!-- Product render filters -->
        <label class="asset-field" id="skuField" hidden>
          <span>SKU</span>
          <select id="assetSku">
            <option value="">Any</option>
            <option value="D7-P5520">D7-P5520</option>
            <option value="D7-PS1010">D7-PS1010</option>
            <option value="D7-PS1030">D7-PS1030</option>
          </select>
        </label>

        <label class="asset-field" id="formFactorField" hidden>
          <span>Form Factor</span>
          <select id="assetFormFactor">
            <option value="">Any</option>
            <option value="E1.L">E1.L</option>
            <option value="E1.S - 9.5mm">E1.S / 9.5mm</option>
            <option value="E3.S">E3.S</option>
            <option value="U.2">U.2</option>
          </select>
        </label>

        <label class="asset-field" id="labelField" hidden>
          <span>Label</span>
          <select id="assetLabel">
            <option value="">Any</option>
            <option value="With Label">With Label</option>
            <option value="Without Label">Without Label</option>
          </select>
        </label>

        <label class="asset-field" id="imageFormatField" hidden>
          <span>Format</span>
          <select id="assetImageFormat">
            <option value="">Any</option>
            <option value="JPG">JPG</option>
            <option value="PNG">PNG</option>
          </select>
        </label>

        <label class="asset-field" id="shadowField" hidden>
          <span>Shadow</span>
          <select id="assetShadow">
            <option value="">Any</option>
            <option value="With Shadow">With Shadow</option>
            <option value="Without Shadow">Without Shadow</option>
          </select>
        </label>

        <!-- Template filters -->
        <label class="asset-field" id="templateTypeField" hidden>
          <span>Type</span>
          <select id="assetTemplateType">
            <option value="">Any</option>
            <option value="presentation">Presentation</option>
            <option value="word">Word</option>
            <option value="excel">Excel</option>
            <option value="email">Email / Signature</option>
            <option value="teams">Teams Background</option>
          </select>
        </label>

      </div><!-- /.asset-controls__subfilters -->
    </div>

    <div class="asset-status" id="assetStatus" aria-live="polite">Loading…</div>

    <div class="asset-grid" id="assetGrid"></div>

    <nav class="asset-pagination" id="assetPagination" aria-label="Asset pagination" hidden>
      <button type="button" class="btn btn--sm btn--secondary" id="assetPrev">← Prev</button>
      <span class="asset-pagination__info" id="assetPageInfo"></span>
      <button type="button" class="btn btn--sm btn--secondary" id="assetNext">Next →</button>
    </nav>
    </div><!-- /.container -->
  </section>

  <!-- Asset preview modal -->
  <div class="asset-modal" id="assetModal" role="dialog" aria-modal="true" aria-labelledby="assetModalTitle" hidden>
    <div class="asset-modal__backdrop" data-modal-close></div>
    <div class="asset-modal__panel" role="document">
      <button type="button" class="asset-modal__close" data-modal-close aria-label="Close preview">×</button>
      <div class="asset-modal__preview" id="assetModalPreview"></div>
      <div class="asset-modal__body">
        <h2 class="asset-modal__title" id="assetModalTitle"></h2>
        <dl class="asset-modal__meta" id="assetModalMeta"></dl>
        <div class="asset-modal__codepaths" id="assetModalCodePaths"></div>
        <div class="asset-modal__actions">
          <button type="button" class="btn btn--sm btn--secondary" id="assetCopyUrl">Copy URL</button>
          <a class="btn btn--sm btn--primary" id="assetDownload" href="#">Download</a>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ mcpUrl }}>
    const API = `${mcpUrl}/api/assets`;
    const PAGE_SIZE = 24;
    const grid = document.getElementById('assetGrid');
    const statusEl = document.getElementById('assetStatus');
    const categoryEl = document.getElementById('assetCategory');
    const colorEl = document.getElementById('assetColor');
    const variantEl = document.getElementById('assetVariant');
    const searchEl = document.getElementById('assetSearch');
    const colorField = document.getElementById('colorField');
    const variantField = document.getElementById('variantField');
    const skuField = document.getElementById('skuField');
    const formFactorField = document.getElementById('formFactorField');
    const labelField = document.getElementById('labelField');
    const imageFormatField = document.getElementById('imageFormatField');
    const shadowField = document.getElementById('shadowField');
    const templateTypeField = document.getElementById('templateTypeField');
    const logoFormatField = document.getElementById('logoFormatField');
    const imageSubcatField = document.getElementById('imageSubcatField');
    const logoFormatEl = document.getElementById('assetLogoFormat');
    const imageSubcatEl = document.getElementById('assetImageSubcat');
    const skuEl = document.getElementById('assetSku');
    const formFactorEl = document.getElementById('assetFormFactor');
    const labelEl = document.getElementById('assetLabel');
    const imageFormatEl = document.getElementById('assetImageFormat');
    const shadowEl = document.getElementById('assetShadow');
    const templateTypeEl = document.getElementById('assetTemplateType');
    const subfiltersRow = document.getElementById('assetSubfilters');
    const resetBtn = document.getElementById('assetReset');
    const pagination = document.getElementById('assetPagination');
    const prevBtn = document.getElementById('assetPrev');
    const nextBtn = document.getElementById('assetNext');
    const pageInfoEl = document.getElementById('assetPageInfo');
    const modal = document.getElementById('assetModal');
    const modalPreview = document.getElementById('assetModalPreview');
    const modalTitle = document.getElementById('assetModalTitle');
    const modalMeta = document.getElementById('assetModalMeta');
    const modalCopy = document.getElementById('assetCopyUrl');
    const modalDownload = document.getElementById('assetDownload');

    let cache = [];
    let currentPage = 1;
    let filteredCache = [];

    async function load() {
      statusEl.textContent = 'Loading…';
      try {
        const res = await fetch(API);
        if (!res.ok) throw new Error(`MCP returned ${res.status}`);
        const data = await res.json();
        cache = data.items || [];
        statusEl.textContent = `${data.local_count ?? 0} local · ${data.sharepoint_count ?? 0} SharePoint · ${cache.length} total`;
        render();
      } catch (err) {
        statusEl.innerHTML = `
          <strong>MCP server unreachable.</strong>
          Start it with <code>cd brand_mcp &amp;&amp; python -m brand_mcp.server</code> or
          set <code>PUBLIC_MCP_URL</code> at build time.<br/>
          <span class="muted">Error: ${err.message}</span>
        `;
      }
    }

    function parseImageSubcat(a) {
      const p = a.rel_path || '';
      const subs = [
        '01. People_Partnerships_Groups',
        '02. Techs Impact',
        '03. People_Industries',
        '04. People_Problem Solvers',
        '05. Tech in Use',
        '06. Data Center_People',
        '07. Data Center',
        '08. Texture',
        '09 - Abstract',
      ];
      return subs.find(s => p.includes(s)) || '';
    }

    function parseProductRender(a) {
      if (!a.rel_path) return {};
      const parts = a.rel_path.replace(/\\/g, '/').split('/');
      const idx = parts.findIndex(p => /product.?render/i.test(p));
      if (idx < 0) return {};
      return {
        sku: (parts[idx + 1] || '').trim(),
        formFactor: (parts[idx + 2] || '').trim(),
        label: (parts[idx + 3] || '').trim(),
        imageFormat: (parts[idx + 4] || '').trim(),
        shadow: (parts[idx + 5] || '').trim(),
      };
    }

    function parseTemplateType(a) {
      const name = (a.name || '').toLowerCase();
      const path = (a.rel_path || '').toLowerCase();
      // Teams backgrounds first (they are JPGs with 'TeamsBG' in name)
      if (/teamsbg|teams.?bg|teams.?background/.test(name)) return 'teams';
      // Excel
      if (/\.xlsx?$/.test(name) || /\bexcel\b/.test(name)) return 'excel';
      // Email signature (check folder path too)
      if (/email.?sig|signature/.test(name) || /email.?sig|email signature/i.test(path)) return 'email';
      // Word / letterhead (.docx / .dotx)
      if (/\.(docx?|dotx?)$/.test(name) || /letterhead/.test(name)) return 'word';
      // PowerPoint presentations
      if (/\.pptx?$/.test(name) || /presentation|powerpoint/.test(name)) return 'presentation';
      return '';
    }

    function updateFilterVisibility(cat) {
      const hasSub = cat && cat !== '';
      // Show/hide the sub-filter row
      subfiltersRow.hidden = !hasSub;

      // Logo
      colorField.hidden        = cat !== 'logo';
      variantField.hidden      = cat !== 'logo';
      logoFormatField.hidden   = cat !== 'logo';
      // Image
      imageSubcatField.hidden  = cat !== 'image';
      // Product render
      skuField.hidden          = cat !== 'product-render';
      formFactorField.hidden   = cat !== 'product-render';
      labelField.hidden        = cat !== 'product-render';
      imageFormatField.hidden  = cat !== 'product-render';
      shadowField.hidden       = cat !== 'product-render';
      // Template
      templateTypeField.hidden = cat !== 'template';
    }

    function render() {
      const cat = categoryEl.value;
      const color = colorEl.value;
      const variant = variantEl.value;
      const logoFormat = logoFormatEl.value;
      const imageSubcat = imageSubcatEl.value;
      const sku = skuEl.value;
      const formFactor = formFactorEl.value;
      const label = labelEl.value;
      const imageFormat = imageFormatEl.value;
      const shadow = shadowEl.value;
      const templateType = templateTypeEl.value;
      const q = searchEl.value.trim().toLowerCase();

      updateFilterVisibility(cat);

      // Show reset if any filter is active
      const anyActive = cat || q || color || variant || logoFormat || imageSubcat ||
        sku || formFactor || label || imageFormat || shadow || templateType;
      resetBtn.hidden = !anyActive;

      filteredCache = cache.filter((a) => {
        if (cat && a.category !== cat) return false;
        // Logo sub-filters
        if (cat === 'logo' && color && a.color !== color) return false;
        if (cat === 'logo' && variant && a.variant !== variant) return false;
        if (cat === 'logo' && logoFormat && a.format !== logoFormat) return false;
        // Image sub-filters
        if (cat === 'image' && imageSubcat && parseImageSubcat(a) !== imageSubcat) return false;
        // Product render sub-filters
        if (cat === 'product-render') {
          const pr = parseProductRender(a);
          if (sku && pr.sku !== sku) return false;
          if (formFactor && pr.formFactor !== formFactor) return false;
          if (label && pr.label !== label) return false;
          if (imageFormat && pr.imageFormat !== imageFormat) return false;
          if (shadow && pr.shadow !== shadow) return false;
        }
        // Template sub-filters
        if (cat === 'template' && templateType && parseTemplateType(a) !== templateType) return false;
        if (q && !(a.name || '').toLowerCase().includes(q)) return false;
        return true;
      });

      currentPage = 1;
      renderPage();
    }

    function renderPage() {
      if (filteredCache.length === 0) {
        grid.innerHTML = '<p class="muted">No assets match your filters.</p>';
        pagination.hidden = true;
        return;
      }

      const totalPages = Math.max(1, Math.ceil(filteredCache.length / PAGE_SIZE));
      if (currentPage > totalPages) currentPage = totalPages;
      const start = (currentPage - 1) * PAGE_SIZE;
      const page = filteredCache.slice(start, start + PAGE_SIZE);

      grid.innerHTML = page
        .map((a, i) => {
          const idx = start + i;
          const isImage = /\.(png|jpg|jpeg|svg|webp|gif)$/i.test(a.name || '');
          // Prefer the CDN thumbnail URL returned by $expand=thumbnails (fast, no proxy needed).
          // Fall back to the proxy for assets that don't have a Graph thumbnail
          // (e.g. EPS, ZIP, PDF) or for local assets.
          let thumbSrc = null;
          if (isImage) {
            if (a.thumbnail_url) {
              thumbSrc = a.thumbnail_url; // direct Microsoft CDN — fastest path
            } else if (a.source === 'sharepoint' && (a.download_url || a.url)) {
              thumbSrc = `http://localhost:8080/api/thumb?url=${encodeURIComponent(a.download_url || a.url)}`;
            } else {
              thumbSrc = a.url;
            }
          }
          const thumb = thumbSrc
            ? `<img src="${thumbSrc}" alt="${a.label || a.filename || 'Asset preview'}" loading="lazy" />`
            : `<div class="asset-card__placeholder">${(a.format || a.category || '?').toUpperCase()}</div>`;
          const meta = [
            a.source === 'sharepoint' ? 'SharePoint' : 'Local',
            a.category,
            a.variant,
            a.color,
            a.resolution,
            a.format,
          ]
            .filter(Boolean)
            .join(' · ');
          const downloadUrl = a.download_url || a.url;
          return `
            <article class="asset-card" data-idx="${idx}" tabindex="0" role="button" aria-label="Preview ${a.name}">
              <div class="asset-card__thumb">${thumb}</div>
              <div class="asset-card__body">
                <h3 class="asset-card__name" title="${a.name}">${a.name}</h3>
                <p class="asset-card__meta">${meta}</p>
                <a class="btn btn--sm btn--secondary" href="${downloadUrl}" data-stop="1" ${
                  a.source === 'local' ? `download="${a.name}"` : 'target="_blank" rel="noopener"'
                }>
                  ${a.source === 'local' ? 'Download' : 'Open ↗'}
                </a>
              </div>
            </article>
          `;
        })
        .join('');

      pagination.hidden = totalPages <= 1;
      pageInfoEl.textContent = `Page ${currentPage} of ${totalPages} · ${filteredCache.length} assets`;
      prevBtn.disabled = currentPage === 1;
      nextBtn.disabled = currentPage === totalPages;
    }

    // Preview modal
    function openModal(asset) {
      const isImage = /\.(png|jpg|jpeg|svg|webp|gif)$/i.test(asset.name || '');
      const previewSrc = asset.download_url || asset.url;
      modalPreview.innerHTML = isImage
        ? `<img src="${previewSrc}" alt="${asset.name}" />`
        : `<div class="asset-modal__placeholder">${(asset.format || asset.category || '?').toUpperCase()}</div>`;
      modalTitle.textContent = asset.name;

      const fields = [
        ['Source', asset.source === 'sharepoint' ? 'SharePoint' : 'Local'],
        ['Category', asset.category],
        ['Variant', asset.variant],
        ['Color', asset.color],
        ['Resolution', asset.resolution],
        ['Format', asset.format],
        ['Size', asset.size_bytes ? `${(asset.size_bytes / 1024).toFixed(1)} KB` : null],
        ['Path', asset.rel_path || asset.path],
      ].filter(([, v]) => v);
      modalMeta.innerHTML = fields
        .map(([k, v]) => `<div><dt>${k}</dt><dd>${v}</dd></div>`)
        .join('');

      // Code paths — where this asset is referenced in the repo (N2)
      const codePaths = Array.isArray(asset.code_paths) ? asset.code_paths : [];
      const codePathsBlock = document.getElementById('assetModalCodePaths');
      if (codePathsBlock) {
        if (codePaths.length === 0) {
          codePathsBlock.innerHTML =
            '<p class="asset-modal__codepaths-empty">No references found in the codebase.</p>';
        } else {
          const items = codePaths
            .map((ref) => `<li><code>${ref.replace(/&/g, '&amp;').replace(/</g, '&lt;')}</code></li>`)
            .join('');
          codePathsBlock.innerHTML =
            `<p class="asset-modal__codepaths-label">Referenced in <strong>${codePaths.length}</strong> location${codePaths.length === 1 ? '' : 's'}:</p>` +
            `<ul class="asset-modal__codepaths-list">${items}</ul>`;
        }
      }

      const downloadUrl = asset.download_url || asset.url;
      modalDownload.href = downloadUrl;
      if (asset.source === 'local') {
        modalDownload.setAttribute('download', asset.name);
        modalDownload.removeAttribute('target');
        modalDownload.textContent = 'Download';
      } else {
        modalDownload.removeAttribute('download');
        modalDownload.setAttribute('target', '_blank');
        modalDownload.setAttribute('rel', 'noopener');
        modalDownload.textContent = 'Open in SharePoint ↗';
      }

      modalCopy.onclick = async () => {
        const absolute = downloadUrl.startsWith('http') ? downloadUrl : `${location.origin}${downloadUrl}`;
        try {
          await navigator.clipboard.writeText(absolute);
          const original = modalCopy.textContent;
          modalCopy.textContent = 'Copied!';
          setTimeout(() => { modalCopy.textContent = original; }, 1200);
        } catch (_) {
          modalCopy.textContent = 'Copy failed';
        }
      };

      modal.hidden = false;
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
    }

    grid.addEventListener('click', (e) => {
      const card = e.target.closest('.asset-card');
      if (!card) return;
      // Don't hijack the direct Download link
      if (e.target.closest('[data-stop]')) return;
      const idx = parseInt(card.dataset.idx, 10);
      const asset = filteredCache[idx];
      if (asset) openModal(asset);
    });
    grid.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      const card = e.target.closest('.asset-card');
      if (!card) return;
      e.preventDefault();
      const idx = parseInt(card.dataset.idx, 10);
      const asset = filteredCache[idx];
      if (asset) openModal(asset);
    });
    modal.addEventListener('click', (e) => {
      if (e.target.closest('[data-modal-close]')) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });

    prevBtn.addEventListener('click', () => {
      if (currentPage > 1) { currentPage--; renderPage(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
    });
    nextBtn.addEventListener('click', () => {
      currentPage++; renderPage(); window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    [categoryEl, colorEl, variantEl, logoFormatEl, imageSubcatEl, skuEl, formFactorEl, labelEl, imageFormatEl, shadowEl, templateTypeEl, searchEl].forEach((el) =>
      el.addEventListener('input', render)
    );

    resetBtn.addEventListener('click', () => {
      categoryEl.value = '';
      colorEl.value = '';
      variantEl.value = '';
      logoFormatEl.value = '';
      imageSubcatEl.value = '';
      skuEl.value = '';
      formFactorEl.value = '';
      labelEl.value = '';
      imageFormatEl.value = '';
      shadowEl.value = '';
      templateTypeEl.value = '';
      searchEl.value = '';
      render();
    });

    load();
  </script>

  <style>
    /* ---------- Quick downloads ---------- */
    .quick-dl {
      margin: 0 0 var(--space-10, 48px);
    }
    .quick-dl__heading {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--color-neutral-600);
      margin: 0 0 var(--space-4, 16px);
    }
    .quick-dl__grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: var(--space-3, 12px);
    }
    .quick-dl__item {
      display: flex;
