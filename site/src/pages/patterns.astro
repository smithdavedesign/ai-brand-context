---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHeader from '~/components/SectionHeader.astro';
import ComponentPreview from '~/components/islands/ComponentPreview.astro';
---
<BaseLayout title="Patterns & Templates" description="Pre-built page patterns, layout templates, and responsive composition rules for Solidigm brand-compliant pages." activeNav="patterns">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Patterns & Templates</span>
      <h1 class="page-hero__title">Reusable flows.</h1>
      <p class="page-hero__lede">
        Common layouts, assembled from tokens and toolkit components. Copy these as
        starting points — then compose from there.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Layout patterns"
        title="Start with a known-good shape."
      />
      <div class="grid grid--2">
        <div class="card">
          <span class="eyebrow">Marketing</span>
          <h3 class="pattern-card-title">Hero + feature grid</h3>
          <p class="text-small muted">Title, lede, primary CTA, three feature cards below.</p>
        </div>
        <div class="card">
          <span class="eyebrow">Forms</span>
          <h3 class="pattern-card-title">Stacked field layout</h3>
          <p class="text-small muted">Labels above inputs, single column, inline validation.</p>
        </div>
        <div class="card">
          <span class="eyebrow">Product</span>
          <h3 class="pattern-card-title">Dashboard shell</h3>
          <p class="text-small muted">Left nav, top bar, content area with card grid.</p>
        </div>
        <div class="card">
          <span class="eyebrow">Content</span>
          <h3 class="pattern-card-title">Article page</h3>
          <p class="text-small muted">Breadcrumb, H1, lede, long-form body with sidebar TOC.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <SectionHeader
        eyebrow="UX best practices"
        title="The rules that keep us on-brand."
      />
      <div class="grid grid--2">
        <div class="card">
          <h3 class="ux-rule-title">Left-aligned body, always</h3>
          <p class="text-small muted">Never center-align blocks of paragraph text. Only short lead-ins, titles, or CTAs may center.</p>
        </div>
        <div class="card">
          <h3 class="ux-rule-title">Weight over decoration</h3>
          <p class="text-small muted">Emphasize with color or weight change — never bold inside a running sentence.</p>
        </div>
        <div class="card">
          <h3 class="ux-rule-title">One primary action</h3>
          <p class="text-small muted">Each view has exactly one primary button. Everything else is secondary or ghost.</p>
        </div>
        <div class="card">
          <h3 class="ux-rule-title">Title case for headlines</h3>
          <p class="text-small muted">Capitalize significant words. Never all-caps for headlines. Uppercase reserved for labels &amp; buttons.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Responsive"
        title="Desktop-first composition, mobile-considered."
        lede="Every pattern has a defined desktop (1920/12-col) and mobile (393/5-col) behavior. Breakpoints between are fluid."
      />
      <ComponentPreview
        title="Fluid hero"
        layout="stack"
        html={`<section class="u-p-16" style="background:var(--light-gray);">
  <span style="font-size:10px; letter-spacing:2px; text-transform:uppercase; color:var(--solidigm-purple); font-weight:var(--font-weight-semibold);">Case study</span>
  <h1 style="max-width:16ch; margin:var(--space-3) 0;">AI-ready storage at hyperscale.</h1>
  <p style="max-width:52ch; color:var(--medium-gray);">Power your most demanding workloads without compromise.</p>
  <div style="margin-top:var(--space-6); display:flex; gap:var(--space-2); flex-wrap:wrap;">
    <button class="tk-btn tk-btn--primary">Request access</button>
    <button class="tk-btn tk-btn--secondary">Read the paper</button>
  </div>
</section>`}
      />
    </div>
  </section>
</BaseLayout>

<style>
.pattern-card-title {
  font-family: var(--font-family-primary);
  font-weight: var(--font-weight-light);
  font-size: var(--fluid-h4);
  margin: var(--space-2) 0;
}
.ux-rule-title {
  font-family: var(--font-family-primary);
  font-weight: var(--font-weight-regular);
  font-size: var(--fluid-h5);
  color: var(--ultra-dark-purple);
  margin: 0 0 var(--space-2);
}
</style>
