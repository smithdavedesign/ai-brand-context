---
import BaseLayout from "~/layouts/BaseLayout.astro";
const mcpUrl = import.meta.env.PUBLIC_MCP_URL || "http://localhost:8080";
---

<BaseLayout title="MCP Telemetry — Solidigm Brand" description="Live telemetry dashboard for the Solidigm Brand MCP server — tool call counts, response times, and error rates.">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Admin · MCP Telemetry</span>
      <h1 class="page-hero__title">Usage stats.</h1>
      <p class="page-hero__lede">
        Aggregated tool usage from <code>brand_mcp</code>. Opt-in via
        <code>BRAND_MCP_TELEMETRY_ENABLED=1</code>. Data never leaves the host.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div id="status" class="admin-status"></div>

      <div class="admin-grid">
        <div>
          <h2 class="admin-h2">Top tools <span class="admin-window">(last 30 days)</span></h2>
          <table class="table" id="tools-table">
            <thead><tr><th>Tool</th><th>Calls</th><th>Errors</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
        <div>
          <h2 class="admin-h2">Top colors looked up <span class="admin-window">(last 30 days)</span></h2>
          <table class="table" id="colors-table">
            <thead><tr><th>Color</th><th>Calls</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>

      <p class="admin-source muted text-xs">
        Source: <code>{mcpUrl}/api/stats?days=30</code>
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ mcpUrl }}>
  (async () => {
    const status     = document.getElementById("status");
    const toolsBody  = document.querySelector("#tools-table tbody");
    const colorsBody = document.querySelector("#colors-table tbody");

    try {
      const res = await fetch(`${mcpUrl}/api/stats?days=30`, { mode: "cors" });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      if (!data.enabled) {
        status.innerHTML =
          `<div class="admin-notice">
            <strong>Telemetry is disabled.</strong>
            Set <code>BRAND_MCP_TELEMETRY_ENABLED=1</code> in
            <code>brand_mcp/.env</code> and restart the server.
          </div>`;
        return;
      }

      status.innerHTML =
        `<dl class="admin-stats">
          <div><dt>Total calls</dt><dd>${data.total_calls}</dd></div>
          <div><dt>Errors</dt><dd>${data.error_count}</dd></div>
          <div><dt>Error rate</dt><dd>${(data.error_rate * 100).toFixed(2)}%</dd></div>
          <div><dt>Avg latency</dt><dd>${data.avg_latency_ms} ms</dd></div>
          <div><dt>Window</dt><dd>${data.window_days} days</dd></div>
        </dl>`;

      for (const row of data.top_tools || [])  {
        const tr = document.createElement("tr");
        tr.innerHTML = `<td><code>${row.name}</code></td><td>${row.calls}</td><td>${row.errors}</td>`;
        toolsBody.appendChild(tr);
      }
      for (const row of data.top_colors || []) {
        const tr = document.createElement("tr");
        tr.innerHTML = `<td>${row.name}</td><td>${row.calls}</td>`;
        colorsBody.appendChild(tr);
      }

      if (!data.top_tools?.length)  toolsBody.innerHTML  = `<tr><td colspan="3" class="muted"><em>No events yet.</em></td></tr>`;
      if (!data.top_colors?.length) colorsBody.innerHTML = `<tr><td colspan="2" class="muted"><em>No color lookups yet.</em></td></tr>`;

    } catch (err) {
      status.innerHTML =
        `<div class="admin-notice admin-notice--error">
          Failed to load stats: ${err.message}.
          Is the MCP server running at <code>${mcpUrl}</code>?
        </div>`;
    }
  })();
</script>

<style>
.admin-h2 {
  font-family: var(--font-family-primary);
  font-weight: var(--font-weight-light);
  font-size: var(--fluid-h4);
  color: var(--ultra-dark-purple);
  margin: 0 0 var(--space-4);
}
.admin-window {
  font-size: 12px;
  font-weight: var(--font-weight-regular);
  color: var(--medium-gray);
  letter-spacing: 0;
}
.admin-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-8);
  margin-top: var(--space-6);
}
@media (max-width: 760px) { .admin-grid { grid-template-columns: 1fr; } }

.admin-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: var(--space-4);
  margin: 0 0 var(--space-8);
}
.admin-stats > div {
  background: var(--light-gray);
  border-left: 3px solid var(--solidigm-purple);
  padding: var(--space-4) var(--space-5);
}
.admin-stats dt {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: var(--font-weight-semibold);
  color: var(--medium-gray);
}
.admin-stats dd {
  margin: var(--space-1) 0 0;
  font-size: var(--fluid-h4);
  font-weight: var(--font-weight-extralight);
  font-family: var(--font-family-primary);
  color: var(--ultra-dark-purple);
}

.admin-notice {
  padding: var(--space-4) var(--space-5);
  background: var(--light-gray);
  border-left: 4px solid var(--solidigm-purple);
  margin-bottom: var(--space-6);
  font-size: 14px;
  color: var(--dark-grey);
}
.admin-notice--error { border-left-color: var(--color-semantic-error, #ba3640); }

.admin-source { margin-top: var(--space-8); }
</style>
</BaseLayout>
