---
import BaseLayout from '~/layouts/BaseLayout.astro';
import TokenFlowDiagram from '~/components/islands/TokenFlowDiagram.astro';
import SectionHeader from '~/components/SectionHeader.astro';
---
<BaseLayout title="Solidigm Design System" activeNav="home">
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <span class="hero__eyebrow">● Solidigm Design System v1.0</span>
      <h1 class="hero__title">One system. <em>Every touchpoint.</em></h1>
      <p class="hero__lede">
        A shared language of tokens, components, and brand rules — so marketing, product, and
        internal teams ship on-brand faster, with less rework.
      </p>
      <div class="hero__ctas">
        <a href="/toolkit" class="btn btn--primary">
          Explore UI Toolkit <span aria-hidden="true">→</span>
        </a>
        <a href="/tokens" class="btn btn--secondary">
          Get Token Package <span aria-hidden="true">→</span>
        </a>
      </div>

      <!-- Metrics strip -->
      <div class="metrics">
        <div class="metrics__item">
          <strong>14</strong>
          <span>brand colors</span>
        </div>
        <div class="metrics__item">
          <strong>28</strong>
          <span>type styles</span>
        </div>
        <div class="metrics__item">
          <strong>17</strong>
          <span>spacing steps</span>
        </div>
        <div class="metrics__item">
          <strong>6</strong>
          <span>output formats</span>
        </div>
        <div class="metrics__item">
          <strong>WCAG 2.1 AA</strong>
          <span>accessibility</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TWO TRACKS -->
  <section class="section section--light">
    <div class="container">
      <SectionHeader
        eyebrow="Two tracks. One system."
        title="Choose what you need — today."
        lede="The design system ships as two distinct artifacts. Use one, the other, or both."
        align="center"
      />
      <div class="grid grid--2" style="max-width: 1040px; margin: 0 auto;">
        <a href="/tokens" class="track-card track-card--npm">
          <span class="badge badge--npm">NPM Package</span>
          <h3>@solidigm/brand-tokens</h3>
          <p class="muted">
            Raw design tokens — colors, typography, spacing — in CSS, SCSS, JS/TS, Tailwind,
            and Figma formats. Single source of truth. Lint-enforced.
          </p>
          <ul class="track-card__list">
            <li>Install via GitHub Packages</li>
            <li>Import in any codebase</li>
            <li>ESLint plugin included</li>
            <li>Tailwind preset included</li>
          </ul>
          <span class="track-card__cta">Explore tokens →</span>
        </a>
        <a href="/toolkit" class="track-card track-card--toolkit">
          <span class="badge badge--toolkit">UI Toolkit</span>
          <h3>ui-toolkit.min.css</h3>
          <p class="muted">
            Ready-made CSS built on tokens — buttons, typography, utilities. Drop in a
            <code>&lt;link&gt;</code> tag and start building. No build step.
          </p>
          <ul class="track-card__list">
            <li>One CSS file</li>
            <li>Pre-built components</li>
            <li>Utility classes</li>
            <li>Fluid typography</li>
          </ul>
          <span class="track-card__cta">Explore toolkit →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Why this exists"
        title="Consistency is speed."
        lede="Every inconsistent button, off-brand color, or one-off spacing value is rework. The design system makes the on-brand choice the easiest choice."
      />
      <div class="grid grid--3">
        <div class="card">
          <div class="why-icon" style="background: rgba(79, 0, 181, 0.1); color: var(--color-purple-500);">✓</div>
          <h3 style="font-size: 20px; margin: 16px 0 8px;">Consistency</h3>
          <p class="muted text-small">
            One token changes everywhere. No more six shades of purple or nine button styles
            across three teams.
          </p>
        </div>
        <div class="card">
          <div class="why-icon" style="background: rgba(0, 255, 236, 0.18); color: var(--color-neutral-900);">↗</div>
          <h3 style="font-size: 20px; margin: 16px 0 8px;">Speed</h3>
          <p class="muted text-small">
            Ship pages in hours, not weeks. Designers pull from Figma libraries; engineers
            import tokens. No custom CSS needed.
          </p>
        </div>
        <div class="card">
          <div class="why-icon" style="background: rgba(255, 108, 90, 0.15); color: var(--color-neutral-900);">∞</div>
          <h3 style="font-size: 20px; margin: 16px 0 8px;">Scalability</h3>
          <p class="muted text-small">
            New product, new region, new channel — the system grows with you. Governance
            keeps the brand intact as teams scale.
          </p>
        </div>
      </div>

      <!-- Before / After -->
      <div class="ba-grid" style="margin-top: var(--space-12, 64px);">
        <div class="ba">
          <div class="ba__label ba__label--before">Before</div>
          <ul>
            <li>30–50% rework on AI-generated UI</li>
            <li>Off-brand colors slip into production</li>
            <li>Hardcoded hex values across 40+ repos</li>
            <li>Figma ≠ code ≠ marketing site</li>
          </ul>
        </div>
        <div class="ba">
          <div class="ba__label ba__label--after">After</div>
          <ul>
            <li>Tokens are the source of truth</li>
            <li>ESLint blocks off-brand colors at PR time</li>
            <li>Figma variables sync with JSON tokens</li>
            <li>One update propagates everywhere</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- TOKEN FLOW -->
  <section class="section section--light">
    <div class="container">
      <SectionHeader
        eyebrow="How the system works"
        title="Token → Component → Page → Product"
        lede="Every surface — from a marketing hero to a product button — traces back to the same token. Change the token, change the experience everywhere."
        align="center"
      />
      <TokenFlowDiagram />
    </div>
  </section>

  <!-- AUDIENCE CARDS -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Start here"
        title="Find your path."
        lede="Different roles need different docs. Jump to the one that fits."
        align="center"
      />
      <div class="grid grid--3">
        <a href="/usage#designers" class="aud-card">
          <span class="eyebrow">For Designers</span>
          <h3>Design in Figma.</h3>
          <p class="muted text-small">
            Pull tokens, components, and the Brand Angle from the Solidigm Figma library.
          </p>
          <span class="aud-card__cta">Designer guide →</span>
        </a>
        <a href="/usage#engineers" class="aud-card">
          <span class="eyebrow">For Engineers</span>
          <h3>Install & import.</h3>
          <p class="muted text-small">
            <code>npm install @solidigm/brand-tokens</code>. Use CSS vars, SCSS, JS, or Tailwind.
          </p>
          <span class="aud-card__cta">Engineer guide →</span>
        </a>
        <a href="/usage#business" class="aud-card">
          <span class="eyebrow">For Business</span>
          <h3>Stay on brand.</h3>
          <p class="muted text-small">
            Know what's possible, what's approved, and how to request something new.
          </p>
          <span class="aud-card__cta">Business guide →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--purple">
    <div class="container" style="text-align: center;">
      <h2 class="section-title">Ready to build on-brand?</h2>
      <p class="section-lede" style="margin: 0 auto var(--space-8, 32px);">
        Start with the toolkit, install the tokens, and ship with confidence.
      </p>
      <div style="display: inline-flex; gap: 16px; flex-wrap: wrap; justify-content: center;">
        <a href="/tokens/usage" class="btn btn--primary" style="background: #fff; color: var(--color-purple-500);">Install the package</a>
        <a href="/toolkit/components" class="btn btn--secondary" style="color: #fff; border-color: #fff;">Browse components</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.metrics {
  display: flex;
  gap: var(--space-8, 32px);
  margin-top: var(--space-10, 48px);
  flex-wrap: wrap;
}
.metrics__item {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.metrics__item strong {
  font-family: 'Sora', sans-serif;
  font-size: 28px;
  font-weight: 200;
  color: var(--color-purple-600);
  line-height: 1;
}
.metrics__item span {
  font-size: 12px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--color-neutral-600);
  margin-top: 4px;
}

.track-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-3, 12px);
  padding: var(--space-8, 32px);
  background: #fff;
  border-radius: var(--border-radius-md, 16px);
  border: 1px solid rgba(0,0,0,0.08);
  color: var(--color-neutral-800);
  transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
}
.track-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 60px rgba(22, 2, 49, 0.1);
  border-color: rgba(79, 0, 181, 0.3);
}
.track-card h3 {
  font-family: 'Sora', sans-serif;
  font-weight: 400;
  font-size: 28px;
  color: var(--color-purple-600);
  margin: 0;
}
.track-card__list {
  list-style: none;
  padding: 0;
  margin: var(--space-3, 12px) 0 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.track-card__list li {
  font-size: 14px;
  color: var(--color-neutral-600);
  padding-left: 20px;
  position: relative;
}
.track-card__list li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--color-purple-500);
}
.track-card__cta {
  margin-top: auto;
  padding-top: var(--space-5, 20px);
  color: var(--color-purple-500);
  font-weight: 500;
  font-size: 14px;
}

.why-icon {
  width: 44px;
  height: 44px;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 600;
}

.ba-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-5, 20px);
}
@media (max-width: 767px) { .ba-grid { grid-template-columns: 1fr; } }
.ba {
  padding: var(--space-6, 24px);
  border-radius: var(--border-radius-md, 16px);
  background: #fff;
  border: 1px solid rgba(0,0,0,0.08);
}
.ba ul { list-style: none; padding: 0; margin: 0; }
.ba li {
  padding: 10px 0 10px 28px;
  position: relative;
  font-size: 14px;
  border-bottom: 1px solid rgba(0,0,0,0.04);
}
.ba li:last-child { border-bottom: 0; }
.ba__label {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 0;
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: 600;
  margin-bottom: 12px;
}
.ba__label--before { background: rgba(186, 54, 64, 0.1); color: #ba3640; }
.ba__label--after { background: rgba(24, 126, 123, 0.12); color: #187e7b; }
.ba__label--before + ul li::before { content: '✕'; color: #ba3640; position: absolute; left: 6px; }
.ba__label--after + ul li::before { content: '✓'; color: #187e7b; position: absolute; left: 6px; font-weight: 700; }

.aud-card {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: var(--space-6, 24px);
  background: #fff;
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: var(--border-radius-md, 16px);
  color: var(--color-neutral-800);
  transition: transform 0.2s, border-color 0.2s;
}
.aud-card:hover { transform: translateY(-2px); border-color: var(--color-purple-500); }
.aud-card h3 {
  font-family: 'Sora', sans-serif;
  font-weight: 300;
  font-size: 22px;
  color: var(--color-purple-600);
  margin: 0;
}
.aud-card__cta {
  margin-top: auto;
  padding-top: var(--space-4, 16px);
  color: var(--color-purple-500);
  font-weight: 500;
  font-size: 14px;
}
</style>
