---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHeader from '~/components/SectionHeader.astro';
import ContrastChecker from '~/components/islands/ContrastChecker.astro';

const voice = [
  { word: 'Optimistic', detail: 'Upbeat, possibility-thinking' },
  { word: 'Analytical', detail: 'Thoughtful, deliberate' },
  { word: 'Passionate', detail: 'Spirited, energized' },
  { word: 'Genuine', detail: 'Authentic, human, dynamic' },
  { word: 'Ambitious', detail: 'Confident, determined — never arrogant' },
];

const values = [
  'Customer Inspired',
  'Invention',
  'Excellence',
  'Openness',
  'Agility',
  'Partnership',
];

const logoRules = [
  { do: 'Purple logo on light backgrounds', dont: 'Purple logo on gray or busy photography' },
  { do: 'White logo on dark backgrounds', dont: 'Colored logo on similar-tone backgrounds' },
  { do: 'Keep the TM mark in the bottom-right', dont: 'Remove, resize, or reposition the TM' },
  { do: 'Minimum 50px (screen) / 13mm (print)', dont: 'Render smaller than minimum size' },
];
---
<BaseLayout title="Brand Foundation" activeNav="brand">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Brand Foundation</span>
      <h1 class="page-hero__title">The Seasoned Challenger.</h1>
      <p class="page-hero__lede">
        Solidigm™ (思得, <em>"See Duh"</em>) — from <em>solid</em> + <em>paradigm</em>. We're
        thought leaders relishing the unsolved. The design system expresses that personality
        across every surface.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Who we are"
        title="Mission, values, personality."
        lede="Brand identity isn't a logo — it's the character that shows up consistently across every interaction."
      />
      <div class="grid grid--2">
        <div class="card">
          <span class="eyebrow">Mission</span>
          <p class="brand-mission">
            Unlock data's virtually unlimited potential through advancements in storage technology.
          </p>
          <p class="text-small muted" style="margin-top: var(--space-3);">Goal: become the #1 NAND business by 2030.</p>
        </div>
        <div class="card">
          <span class="eyebrow">Values</span>
          <div style="display:flex; flex-wrap:wrap; gap:var(--space-2); margin-top: var(--space-3);">
            {values.map((v) => (
              <span class="badge badge--npm">{v}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <SectionHeader
        eyebrow="Voice & Tone"
        title="Five words. One personality."
        lede="Every headline, every button label, every error message should sound like the same brand speaking."
      />
      <div class="grid grid--3">
        {voice.map((v) => (
          <div class="card">
            <h3 class="voice-word">{v.word}</h3>
            <p class="text-small muted" style="margin:0;">{v.detail}</p>
          </div>
        ))}
      </div>
      <p class="text-small muted" style="margin-top: var(--space-6); max-width: 680px;">
        <strong>Never:</strong> arrogant, condescending, overly technical, or corporate-cold.
        Write like a thoughtful expert who genuinely cares about the reader's problem.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Logo system"
        title="The mark is the brand."
        lede="The S is derived from interlocking SSD shapes built on 45° and 90° angles — a visual DNA of precision partnership."
      />
      <div class="logo-demo">
        <div class="logo-demo__stage logo-demo__stage--light">
          <div class="logo-demo__mark">
            <!-- Purple logo on light — fill controlled via CSS class -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="24 352 416 376" aria-hidden="true" class="logo-svg logo-svg--purple">
              <polygon points="170.83,362.38 34.41,498.81 34.41,584.28 77.4,627.28 246.85,627.28 324.57,549.56 324.57,505.06 233.81,595.81 65.87,595.81 65.87,511.84 183.86,393.85 324.57,393.85 324.57,362.38"/>
              <polygon points="217.95,452.72 140.24,530.44 140.24,574.94 230.99,484.19 398.93,484.19 398.93,568.16 280.94,686.15 140.24,686.15 140.24,717.62 293.97,717.62 430.4,581.19 430.4,495.72 387.4,452.72"/>
            </svg>
          </div>
          <span class="logo-demo__caption">On light · Purple</span>
        </div>
        <div class="logo-demo__stage logo-demo__stage--dark">
          <div class="logo-demo__mark">
            <!-- White logo on dark — fill controlled via CSS class -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="24 352 416 376" aria-hidden="true" class="logo-svg logo-svg--white">
              <polygon points="170.83,362.38 34.41,498.81 34.41,584.28 77.4,627.28 246.85,627.28 324.57,549.56 324.57,505.06 233.81,595.81 65.87,595.81 65.87,511.84 183.86,393.85 324.57,393.85 324.57,362.38"/>
              <polygon points="217.95,452.72 140.24,530.44 140.24,574.94 230.99,484.19 398.93,484.19 398.93,568.16 280.94,686.15 140.24,686.15 140.24,717.62 293.97,717.62 430.4,581.19 430.4,495.72 387.4,452.72"/>
            </svg>
          </div>
          <span class="logo-demo__caption">On dark · White</span>
        </div>
        <div class="logo-demo__stage logo-demo__stage--gray">
          <div class="logo-demo__mark">
            <!-- Dark logo on neutral — fill controlled via CSS class -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="24 352 416 376" aria-hidden="true" class="logo-svg logo-svg--dark">
              <polygon points="170.83,362.38 34.41,498.81 34.41,584.28 77.4,627.28 246.85,627.28 324.57,549.56 324.57,505.06 233.81,595.81 65.87,595.81 65.87,511.84 183.86,393.85 324.57,393.85 324.57,362.38"/>
              <polygon points="217.95,452.72 140.24,530.44 140.24,574.94 230.99,484.19 398.93,484.19 398.93,568.16 280.94,686.15 140.24,686.15 140.24,717.62 293.97,717.62 430.4,581.19 430.4,495.72 387.4,452.72"/>
            </svg>
          </div>
          <span class="logo-demo__caption">On medium · Black</span>
        </div>
      </div>

      <div class="dodont" style="margin-top: var(--space-8);">
        {logoRules.map((r) => (
          <>
            <div class="dodont__item dodont__item--do">
              <div class="dodont__preview">{r.do}</div>
              <div class="dodont__label">Do</div>
            </div>
            <div class="dodont__item dodont__item--dont">
              <div class="dodont__preview">{r.dont}</div>
              <div class="dodont__label">Don't</div>
            </div>
          </>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <SectionHeader
        eyebrow="Color philosophy"
        title="Lead with purple. Accent with restraint."
        lede="Purple is Solidigm. Dark backgrounds frame depth. Grays do the quiet work. Accent colors (teal, pink, orange) are reserved — never dominant."
      />
      <div class="grid grid--4">
        <div class="phil-chip" style="background: var(--solidigm-purple); color: var(--color-neutral-0);">
          <strong>Purple</strong>
          <span>Lead color</span>
        </div>
        <div class="phil-chip" style="background: var(--dark-blue); color: var(--color-neutral-0);">
          <strong>Dark Blue</strong>
          <span>Depth, overlays</span>
        </div>
        <div class="phil-chip" style="background: var(--color-neutral-50); color: var(--color-neutral-800); border:1px solid rgba(0,0,0,0.08);">
          <strong>Grays</strong>
          <span>Structure, quiet</span>
        </div>
        <div class="phil-chip" style="background: var(--color-accent-teal); color: var(--color-neutral-900);">
          <strong>Accents</strong>
          <span>Highlights only ⚠</span>
        </div>
      </div>
      <p class="text-small muted" style="margin-top: var(--space-5); max-width: 680px;">
        Accent colors (Electric Teal, Electric Pink, Orange) require brand approval for any
        dominant use. See <a href="/tokens/colors">all tokens</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Typography"
        title="Sora, with weight as hierarchy."
        lede="We use Sora (Google Fonts, free) across every surface. Thin (200) for headlines, not size alone. Weight is how we create emphasis — not bold-inside-sentences."
      />
      <div class="type-philosophy">
        <div class="type-philosophy__sample">
          Paradigm shift.
        </div>
        <div class="type-philosophy__note">
          <p><strong>Headlines:</strong> Sora Thin (200) or ExtraLight. Title case. Never all-caps.</p>
          <p><strong>Body:</strong> Light (300) or Regular (400). Left-aligned only. No center-aligned paragraphs.</p>
          <p><strong>Buttons & labels:</strong> SemiBold (600), 10px, uppercase, 2px tracking.</p>
          <p><strong>Emphasis:</strong> Use color or custom frames. <em>Never bold inside a sentence.</em></p>
        </div>
      </div>
      <p class="text-small muted" style="margin-top: var(--space-6);">
        CJK languages use <a href="https://fonts.google.com/noto/specimen/Noto+Sans">Noto Sans</a>.
        Microsoft Office documents use Avenir Next LT Pro.
      </p>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <SectionHeader
        eyebrow="Accessibility"
        title="WCAG 2.1 AA, always."
        lede="Every color pairing in the system passes 4.5:1 minimum contrast. Try any combination below — if a brand color combination fails, it's not a valid pairing."
      />
      <ContrastChecker />
    </div>
  </section>
</BaseLayout>

<style>
/* Mission statement pull-quote style */
.brand-mission {
  font-size: var(--fluid-h5);
  font-weight: var(--font-weight-light);
  color: var(--ultra-dark-purple);
  margin-top: var(--space-2);
}

/* Voice pillar word */
.voice-word {
  font-family: var(--font-family-primary);
  font-weight: var(--font-weight-extralight);
  font-size: var(--fluid-h3);
  color: var(--solidigm-purple);
  margin: 0 0 var(--space-2);
}

/* Logo demo grid */
.logo-demo {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: var(--space-5);
}
.logo-demo__stage {
  padding: var(--space-10) var(--space-6);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-4);
  border: 1px solid rgba(0,0,0,0.06);
}
.logo-demo__stage--light { background: var(--color-neutral-50); }
.logo-demo__stage--dark  { background: var(--dark-blue); color: var(--color-neutral-0); }
.logo-demo__stage--gray  { background: var(--color-neutral-600); color: var(--color-neutral-0); }
.logo-demo__mark {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-4) 0;
}
.logo-demo__mark svg {
  width: 120px;
  height: auto;
  display: block;
}
/* SVG fill via CSS — no hardcoded hex in markup */
.logo-svg--purple polygon { fill: var(--solidigm-purple); }
.logo-svg--white  polygon { fill: var(--color-neutral-0); }
.logo-svg--dark   polygon { fill: var(--color-neutral-900); }

.logo-demo__caption {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: var(--font-weight-semibold);
}

/* Color philosophy chips */
.phil-chip {
  padding: var(--space-6);
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  min-height: 140px;
  justify-content: flex-end;
}
.phil-chip strong {
  font-size: var(--fluid-h5);
  font-weight: var(--font-weight-medium);
}
.phil-chip span {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: var(--font-weight-semibold);
  opacity: 0.85;
}

/* Typography philosophy */
.type-philosophy {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-8);
  align-items: center;
}
@media (max-width: 767px) { .type-philosophy { grid-template-columns: 1fr; } }
.type-philosophy__sample {
  font-family: var(--font-family-primary);
  font-weight: var(--font-weight-extralight);
  font-size: clamp(40px, 6vw, 88px);
  line-height: 1;
  color: var(--ultra-dark-purple);
}
.type-philosophy__note p {
  margin: 0 0 var(--space-3);
  color: var(--medium-gray);
  line-height: 1.6;
}
.type-philosophy__note p strong { color: var(--ultra-dark-purple); font-weight: var(--font-weight-semibold); }
</style>
