---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHeader from '~/components/SectionHeader.astro';
---
<BaseLayout title="Showcase" activeNav="home">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Showcase</span>
      <h1 class="page-hero__title">Real examples.</h1>
      <p class="page-hero__lede">
        Every surface on this very site is built with the Solidigm Design System. The best
        proof is the site you're reading.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Self-referential"
        title="This site eats its own dog food."
        lede="No custom CSS snowflakes, no hardcoded colors, no one-off fonts. Every pixel traces back to a token."
      />
      <div class="grid grid--2">
        <div class="card">
          <h3 style="margin:0 0 var(--space-2); font-size:var(--fluid-h5);">What you see</h3>
          <ul class="text-small muted" style="padding-left:var(--space-4);">
            <li>Hero typography: <code>DT Hero</code>, <code>DT Headline 1</code></li>
            <li>All purples: <code>--solidigm-purple</code>, <code>--ultra-dark-purple</code></li>
            <li>Spacing: <code>--space-*</code> 4pt scale</li>
            <li>Buttons: <code>.btn--primary</code>, <code>.tk-btn</code> from the toolkit</li>
            <li>Corners: <code>--border-radius-sm: 0</code> — always square</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin:0 0 var(--space-2); font-size:var(--fluid-h5);">What you don't see</h3>
          <ul class="text-small muted" style="padding-left:var(--space-4);">
            <li>Any hardcoded hex values</li>
            <li>Any magic numbers for spacing</li>
            <li>Any font beyond Sora</li>
            <li>Any one-off breakpoint hacks</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <SectionHeader
        eyebrow="Before / After"
        title="Consistency you can feel."
        lede="Two versions of the same page. One ad-hoc, one on-system."
      />
      <div class="ba-showcase">
        <!-- brand-audit:exempt -->
        <div class="ba-mock ba-mock--before">
          <div class="ba-mock__header">Before — ad-hoc</div>
          <div style="padding:24px;">
            <div style="font-family:Arial; font-size:28px; color:#5a00a0; font-weight:700;">Storage, done right</div>
            <div style="font-family:Arial; font-size:13px; color:#333; margin-top:8px;">Lorem ipsum dolor sit amet.</div>
            <button style="margin-top:14px; background:#6600cc; color:#fff; border:0; padding:10px 18px; border-radius:3px; font-family:Arial; font-size:13px;">CLICK HERE</button>
          </div>
        </div>
        <!-- /brand-audit:exempt -->

        <div class="ba-mock ba-mock--after">
          <div class="ba-mock__header">After — on-system</div>
          <div style="padding:var(--space-6);">
            <div style="font-weight:var(--font-weight-extralight); font-size:var(--fluid-h3); color:var(--ultra-dark-purple); line-height:1.1;">Storage, done right.</div>
            <div style="font-weight:var(--font-weight-light); color:var(--medium-gray); margin-top:var(--space-3); line-height:1.5;">Unlock data's virtually unlimited potential through Solidigm storage.</div>
            <button class="tk-btn tk-btn--primary" style="margin-top:var(--space-4);">Explore products</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--purple">
    <div class="container" style="text-align:center;">
      <h2 class="section-title">Ready to build on-brand?</h2>
      <p class="section-lede" style="margin: 0 auto var(--space-8, 32px);">
        The system is live, documented, and enforced. Your turn.
      </p>
      <div style="display:inline-flex; gap:var(--space-4); flex-wrap:wrap; justify-content:center;">
        <a href="/tokens/usage" class="btn btn--on-dark">Install the tokens</a>
        <a href="/toolkit" class="btn btn--ghost">Use the toolkit</a>
        <a href="https://github.com/solidigm/ai-brand-context" class="btn btn--ghost">View the source ↗</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.ba-showcase {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-5);
}
@media (max-width: 767px) { .ba-showcase { grid-template-columns: 1fr; } }
.ba-mock {
  overflow: hidden;
  border: 1px solid rgba(0,0,0,0.08);
  background: var(--color-neutral-0);
}
.ba-mock__header {
  padding: var(--space-2) var(--space-4);
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: var(--font-weight-semibold);
  color: var(--color-neutral-0);
}
.ba-mock--before .ba-mock__header { background: var(--color-semantic-error); }
.ba-mock--after .ba-mock__header { background: #187e7b; }
</style>
