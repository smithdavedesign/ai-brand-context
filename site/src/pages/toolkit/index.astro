---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CodeBlock from '~/components/CodeBlock.astro';
---
<BaseLayout title="UI Toolkit" activeNav="toolkit">
  <section class="page-hero">
    <div class="container">
      <span class="badge badge--toolkit">UI Toolkit</span>
      <h1 class="page-hero__title">Ready-made CSS.</h1>
      <p class="page-hero__lede">
        <code>ui-toolkit.min.css</code> is a single CSS file that gives you buttons,
        typography, and utilities built on the token system — no build step, no framework.
        Drop it in with a <code>&lt;link&gt;</code> tag.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="layout-docs">
        <aside class="sidebar">
          <h4>Toolkit</h4>
          <ul>
            <li><a href="/toolkit" class="active">Overview</a></li>
            <li><a href="/toolkit/foundations">Foundations</a></li>
            <li><a href="/toolkit/components">Components</a></li>
            <li><a href="/toolkit/utilities">Utilities</a></li>
          </ul>
        </aside>
        <div class="stack-lg">
          <div>
            <h2 class="doc-h2">Toolkit vs Tokens</h2>
            <p class="muted" style="max-width:720px;">
              Two separate deliverables. They share a source of truth but serve different needs.
            </p>
            <table class="table" style="margin-top: var(--space-4, 16px);">
              <thead>
                <tr><th></th><th>NPM Token Package</th><th>UI Toolkit CSS</th></tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>What it is</strong></td>
                  <td>Raw design tokens (colors, type, spacing)</td>
                  <td>A compiled CSS file with components + utilities</td>
                </tr>
                <tr>
                  <td><strong>How you use it</strong></td>
                  <td><code>npm install</code>, import in code</td>
                  <td><code>&lt;link rel="stylesheet"&gt;</code> — that's it</td>
                </tr>
                <tr>
                  <td><strong>Build step</strong></td>
                  <td>Requires a bundler (Webpack, Vite, etc.)</td>
                  <td>None — works in plain HTML</td>
                </tr>
                <tr>
                  <td><strong>Best for</strong></td>
                  <td>React/Next/Vue/Svelte apps, design systems</td>
                  <td>Marketing pages, CMS content, prototypes, AEM</td>
                </tr>
                <tr>
                  <td><strong>Customizable</strong></td>
                  <td>Full access to every token</td>
                  <td>Pre-made classes; customize via CSS vars</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div>
            <h2 class="doc-h2">Install</h2>
            <p class="muted" style="max-width:720px;">
              Reference the file from CDN or copy it into your project's static assets. Sora
              is loaded automatically via Google Fonts.
            </p>
            <CodeBlock lang="html" filename="index.html" code={`<!doctype html>
<html lang="en">
  <head>
    <link rel="stylesheet" href="/assets/ui-toolkit.min.css" />
  </head>
  <body>
    <h1>Hello, Solidigm</h1>
    <button class="tk-btn tk-btn--primary">Get started</button>
  </body>
</html>`} />
          </div>

          <div>
            <h2 class="doc-h2">What's inside</h2>
            <div class="grid grid--3">
              <a href="/toolkit/foundations" class="card">
                <span class="eyebrow">Foundations</span>
                <h4 class="toolkit-card-h4">Typography & utilities</h4>
                <p class="text-small muted">Fluid heading classes, color utilities, spacing helpers.</p>
              </a>
              <a href="/toolkit/components" class="card">
                <span class="eyebrow">Components</span>
                <h4 class="toolkit-card-h4">Buttons, cards, forms</h4>
                <p class="text-small muted">Pre-built HTML patterns with hover/focus states.</p>
              </a>
              <a href="/toolkit/utilities" class="card">
                <span class="eyebrow">Utilities</span>
                <h4 class="toolkit-card-h4">Layout helpers</h4>
                <p class="text-small muted">Flex, spacing, responsive visibility, effects.</p>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.doc-h2 {
  font-family: var(--font-family-primary);
  font-weight: var(--font-weight-light);
  font-size: var(--fluid-h3);
  color: var(--ultra-dark-purple);
  margin: 0 0 var(--space-2);
}
.toolkit-card-h4 {
  margin: var(--space-2) 0;
  font-size: var(--fluid-h5);
  font-weight: var(--font-weight-regular);
}
</style>
