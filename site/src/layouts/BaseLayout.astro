---
import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';
import '~/styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeNav?: 'home' | 'brand' | 'tokens' | 'toolkit' | 'assets' | 'patterns' | 'usage' | 'governance' | 'compliance';
}

const {
  title,
  description = 'Solidigm Design System — one system, every touchpoint. Tokens, UI toolkit, brand foundation, and governance.',
  activeNav = 'home',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} · Solidigm Design System`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>

    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="Solidigm Design System" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Solidigm Design System",
      "url": Astro.site?.href,
      "description": "Canonical source of truth for Solidigm design tokens, UI toolkit, brand guidelines, and governance.",
      "publisher": {
        "@type": "Organization",
        "name": "Solidigm",
        "url": "https://www.solidigm.com"
      }
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Sora:wght@200;300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <!-- Self-consume the UI toolkit CSS from this repo (dogfooding) -->
    <link rel="stylesheet" href="/ui-toolkit.min.css" />
  </head>
  <body>
    <Nav active={activeNav} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  // Inject a collapse toggle before every .sidebar on mobile.
  // Reads the active link label to show context ("On this page · Colors").
  document.querySelectorAll<HTMLElement>('.sidebar').forEach((sidebar) => {
    const activeLink = sidebar.querySelector<HTMLElement>('a.active');
    const activeLabel = activeLink?.textContent?.trim() ?? '';

    const btn = document.createElement('button');
    btn.className = 'sidebar-toggle';
    btn.setAttribute('aria-expanded', 'false');
    btn.setAttribute('aria-controls', 'sidebar-nav');
    sidebar.id = 'sidebar-nav';
    btn.innerHTML = `
      <span>On this page${activeLabel ? `<span class="sidebar-toggle__active-page"> · ${activeLabel}</span>` : ''}</span>
      <svg class="sidebar-toggle__chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2 4.5L7 9.5L12 4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"/>
      </svg>
    `;

    btn.addEventListener('click', () => {
      const open = sidebar.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(open));
    });

    sidebar.parentElement?.insertBefore(btn, sidebar);
  });
</script>
